<Window x:Class="Yoink.UI.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MouseEnter="OnMouseEnter"
        MouseLeave="OnMouseLeave">

    <Border x:Name="RootBorder" CornerRadius="12" Padding="6" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid>
            <!-- Screenshot thumbnail -->
            <Border CornerRadius="8" ClipToBounds="True">
                <Image x:Name="ThumbnailImage" Stretch="Uniform"
                       MaxWidth="300" MaxHeight="200" MinWidth="120" MinHeight="80"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <!-- Save icon (bottom-right) -->
            <Border x:Name="SaveBtn" Width="28" Height="28" CornerRadius="6"
                    Cursor="Hand" MouseLeftButtonDown="SaveClick"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,6,6" ToolTip="Save to file">
                <Path Data="M19,12v7H5v-7H3v7c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2v-7H19z M13,12.67l2.59-2.58L17,11.5l-5,5l-5-5l1.41-1.41L11,12.67V3h2V12.67z"
                      Stretch="Uniform" Width="14" Height="14" Opacity="0.9"/>
            </Border>
        </Grid>
    </Border>
</Window>
