<Window x:Class="Yoink.UI.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MouseEnter="OnMouseEnter"
        MouseLeave="OnMouseLeave">

    <Grid>
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="DragScale" ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="SlideX" X="0"/>
            </TransformGroup>
        </Grid.RenderTransform>

        <Border x:Name="ImageBorder" MaxWidth="280" MaxHeight="180" MinWidth="100"
                CornerRadius="12" Background="#2C2C2C">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.5" Color="Black"/>
            </Border.Effect>
            <Border.Clip>
                <RectangleGeometry x:Name="ImageClip" RadiusX="12" RadiusY="12"/>
            </Border.Clip>
            <Image x:Name="ThumbnailImage" Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <!-- White stroke on top -->
        <Border x:Name="RootBorder" CornerRadius="12" BorderThickness="1.5"
                BorderBrush="#CCFFFFFF" Background="Transparent"
                MaxWidth="280" MaxHeight="180" MinWidth="100"
                IsHitTestVisible="False"/>

        <!-- X close -->
        <Border x:Name="CloseBtn" Width="20" Height="20" CornerRadius="10"
                Background="#90000000" Cursor="Hand"
                MouseLeftButtonDown="CloseClick"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,3,3,0" Opacity="0"/>

        <!-- Save button -->
        <Border x:Name="SaveBtn" Width="36" Height="36" CornerRadius="8"
                Background="Transparent" Cursor="Hand"
                MouseLeftButtonDown="SaveClick"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,0,0" Opacity="0">
            <Border Background="#70000000" CornerRadius="6" Width="26" Height="26"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Data="M19,12v7H5v-7H3v7c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2v-7H19z M13,12.67l2.59-2.58L17,11.5l-5,5l-5-5l1.41-1.41L11,12.67V3h2V12.67z"
                      Fill="White" Stretch="Uniform" Width="11" Height="11" Opacity="0.9"/>
            </Border>
        </Border>
    </Grid>
</Window>
