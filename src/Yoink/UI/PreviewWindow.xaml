<Window x:Class="Yoink.UI.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MouseEnter="OnMouseEnter"
        MouseLeave="OnMouseLeave">

    <Border x:Name="RootBorder" CornerRadius="10" Padding="4" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.35" Color="Black"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="DragScale" ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="SlideX" X="0"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Grid>
            <Border CornerRadius="7" ClipToBounds="True">
                <Image x:Name="ThumbnailImage" Stretch="Uniform"
                       MaxWidth="280" MaxHeight="180" MinWidth="100"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <!-- X close -->
            <Border x:Name="CloseBtn" Width="20" Height="20" CornerRadius="10"
                    Background="#90000000" Cursor="Hand"
                    MouseLeftButtonDown="CloseClick"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,3,3,0" Opacity="0">
                <Canvas Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Line X1="0" Y1="0" X2="8" Y2="8" Stroke="White" StrokeThickness="1.5"/>
                    <Line X1="8" Y1="0" X2="0" Y2="8" Stroke="White" StrokeThickness="1.5"/>
                </Canvas>
            </Border>

            <!-- Save button - LARGER hit area (36x36 transparent, icon inside) -->
            <Border x:Name="SaveBtn" Width="36" Height="36" CornerRadius="8"
                    Background="Transparent" Cursor="Hand"
                    MouseLeftButtonDown="SaveClick"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,0,0" Opacity="0">
                <Border Background="#70000000" CornerRadius="6" Width="26" Height="26"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Path Data="M19,12v7H5v-7H3v7c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2v-7H19z M13,12.67l2.59-2.58L17,11.5l-5,5l-5-5l1.41-1.41L11,12.67V3h2V12.67z"
                          Fill="White" Stretch="Uniform" Width="11" Height="11" Opacity="0.9"/>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
