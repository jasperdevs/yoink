<Window x:Class="Yoink.UI.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Opacity="0"
        MouseEnter="OnMouseEnter"
        MouseLeave="OnMouseLeave">

    <Border x:Name="ImageBorder" MinWidth="120" MinHeight="80"
            CornerRadius="12" Background="#2C2C2C" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.6" Color="Black"/>
        </Border.Effect>
        <Border.Clip>
            <RectangleGeometry x:Name="ImageClip" RadiusX="12" RadiusY="12"/>
        </Border.Clip>
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="DragScale" ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="SlideX" X="0"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Grid>
            <Image x:Name="ThumbnailImage" Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Stroke overlay - dark works on both light and dark backgrounds -->
            <Border x:Name="RootBorder" CornerRadius="12" Background="Transparent"
                    BorderBrush="#40000000" BorderThickness="1"
                    IsHitTestVisible="False"/>

            <!-- X close (inside, top-right of image) -->
            <Border x:Name="CloseBtn" Width="28" Height="28" CornerRadius="6"
                    Background="#70000000" Cursor="Hand"
                    MouseLeftButtonDown="CloseClick"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,5,5,0" Opacity="0"
                    ToolTip="Close">
                <Canvas Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Line X1="0" Y1="0" X2="8" Y2="8" Stroke="White" StrokeThickness="1.5"/>
                    <Line X1="8" Y1="0" X2="0" Y2="8" Stroke="White" StrokeThickness="1.5"/>
                </Canvas>
            </Border>

            <!-- Pin button (inside, bottom-left of image) -->
            <Border x:Name="PinBtn" Width="28" Height="28" CornerRadius="6"
                    Background="#70000000" Cursor="Hand"
                    MouseLeftButtonDown="PinClick"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="5,0,0,5" Opacity="0"
                    ToolTip="Pin to screen">
                <Path x:Name="PinIcon"
                      Data="M16,12V4h1V2H7V4h1v8l-2,2v2h5.2v6h1.6v-6H18v-2Z"
                      Fill="White" Stretch="Uniform" Width="12" Height="12" Opacity="0.9"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Save button (inside, bottom-right of image) -->
            <Border x:Name="SaveBtn" Width="28" Height="28" CornerRadius="6"
                    Background="#70000000" Cursor="Hand"
                    MouseLeftButtonDown="SaveClick"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,5,5" Opacity="0"
                    ToolTip="Save to file">
                <Path Data="M19,12v7H5v-7H3v7c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2v-7H19z M13,12.67l2.59-2.58L17,11.5l-5,5l-5-5l1.41-1.41L11,12.67V3h2V12.67z"
                      Fill="White" Stretch="Uniform" Width="11" Height="11" Opacity="0.9"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
