<Window x:Class="Yoink.UI.InstallWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Width="520" MinHeight="600" SizeToContent="Height" Topmost="True"
        SourceInitialized="OnSourceInit"
        MouseLeftButtonDown="Window_MouseDown">

    <Window.Resources>
        <Style x:Key="WizBtn" TargetType="Button" BasedOn="{StaticResource ChromeButtonBase}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style x:Key="WizBtnPrimary" TargetType="Button" BasedOn="{StaticResource WizBtn}">
            <Setter Property="Background" Value="{DynamicResource WizBtnPrimaryBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource WizBtnPrimaryFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WizBtnPrimaryBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="WizBtnSecondary" TargetType="Button" BasedOn="{StaticResource WizBtn}">
            <Setter Property="Background" Value="{DynamicResource WizBtnSecondaryBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource WizBtnSecondaryFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WizBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="WizRow" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource WizCardBg}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WizBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Border Margin="16" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.5" Color="{DynamicResource WizShadowColor}"/>
        </Border.Effect>
    <Border x:Name="WizardBorder" CornerRadius="12" ClipToBounds="True"
            Background="{DynamicResource WizBg}" BorderBrush="{DynamicResource WizBorder}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page 1: Install location + options -->
        <Grid x:Name="Page1" Grid.Row="0" Margin="36,24,36,0">
            <StackPanel VerticalAlignment="Center">
                <Image Source="pack://application:,,,/yoink.ico" Width="48" Height="48"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Install Yoink" FontSize="26" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display"
                           Foreground="{DynamicResource WizFg}" HorizontalAlignment="Center"/>
                <TextBlock Text="Fast screenshots, screen recording, and more." FontSize="13"
                           FontFamily="Segoe UI Variable Text"
                           Foreground="{DynamicResource WizFgMuted}" HorizontalAlignment="Center" Margin="0,4,0,18"/>

                <!-- Install location -->
                <Border Style="{StaticResource WizRow}">
                    <StackPanel>
                        <TextBlock Text="Install to" FontSize="12" Foreground="{DynamicResource WizFgMuted}" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InstallPathBox" FontSize="12" Padding="8,6"
                                     FontFamily="Segoe UI Variable Text"
                                     Background="{DynamicResource WizInputBg}"
                                     Foreground="{DynamicResource WizFg}"
                                     BorderBrush="{DynamicResource WizBorder}"/>
                            <Button Grid.Column="1" Content="Browse" Style="{StaticResource WizBtnSecondary}"
                                    Padding="12,6" MinWidth="0" Margin="6,0,0,0" FontSize="11"
                                    Click="Browse_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Options -->
                <Border Style="{StaticResource WizRow}">
                    <StackPanel>
                        <CheckBox x:Name="DesktopShortcutCheck" Content="Create desktop shortcut" FontSize="13"
                                  Foreground="{DynamicResource WizFg}" Cursor="Hand" IsChecked="True"/>
                        <CheckBox x:Name="StartMenuCheck" Content="Create Start Menu shortcut" FontSize="13"
                                  Foreground="{DynamicResource WizFg}" Cursor="Hand" IsChecked="True" Margin="0,6,0,0"/>
                        <CheckBox x:Name="StartWithWindowsCheck" Content="Start with Windows" FontSize="13"
                                  Foreground="{DynamicResource WizFg}" Cursor="Hand" IsChecked="True" Margin="0,6,0,0"/>
                        <CheckBox x:Name="LaunchAfterCheck" Content="Launch Yoink after install" FontSize="13"
                                  Foreground="{DynamicResource WizFg}" Cursor="Hand" IsChecked="True" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Page 2: Installing / Complete -->
        <Grid x:Name="Page2" Grid.Row="0" Margin="36,24,36,0" Visibility="Collapsed">
            <StackPanel x:Name="InstallingContent" VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Render ICO at 256px source, display at 48px so scaling stays crisp -->
                <Image x:Name="Page2Logo" Source="pack://application:,,,/yoink.ico"
                       Width="48" Height="48"
                       RenderOptions.BitmapScalingMode="Fant"
                       HorizontalAlignment="Center" Margin="0,0,0,16"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1"/>
                    </Image.RenderTransform>
                </Image>
                <TextBlock x:Name="StatusText" Text="Installing..." FontSize="22" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display"
                           Foreground="{DynamicResource WizFg}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="StatusDetail" Text="Copying files..." FontSize="13"
                           FontFamily="Segoe UI Variable Text"
                           Foreground="{DynamicResource WizFgMuted}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <ProgressBar x:Name="ProgressBar" IsIndeterminate="True" Height="3" Margin="40,20,40,0"
                             Foreground="{DynamicResource WizProgressFg}" Background="{DynamicResource WizProgressBg}"/>
            </StackPanel>
        </Grid>

        <!-- Completion fade overlay — inside WizardBorder so corner radius clips it -->
        <Border x:Name="CompletionOverlay" Grid.RowSpan="2" Background="{DynamicResource WizBg}"
                Opacity="0" IsHitTestVisible="False"/>

        <!-- Bottom bar -->
        <Border Grid.Row="1" Padding="28,10,28,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="CancelBtn" Content="Cancel" Style="{StaticResource WizBtnSecondary}"
                        HorizontalAlignment="Left" Click="Cancel_Click"/>
                <Button x:Name="InstallBtn" Content="Install" Style="{StaticResource WizBtnPrimary}"
                        Grid.Column="1" Click="Install_Click"/>
            </Grid>
        </Border>
    </Grid>
    </Border>
    </Border>
</Window>
