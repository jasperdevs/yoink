<Window x:Class="Yoink.UI.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yoink"
        WindowStartupLocation="CenterOwner"
        ThemeMode="Dark"
        Background="#1C1C1C"
        KeyDown="OnKeyDown"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border CornerRadius="12" ClipToBounds="True" Background="#1C1C1C"
            BorderBrush="#CCFFFFFF" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <Grid>
            <!-- Full-bleed image -->
            <Image x:Name="ViewerImage" Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Top bar: info left, buttons right, frosted -->
            <Border VerticalAlignment="Top" Padding="14,10,14,10"
                    MouseLeftButtonDown="DragWindow">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#C0000000" Offset="0"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <TextBlock x:Name="InfoText" FontSize="11" Opacity="0.6"
                               Foreground="White" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Copy" FontSize="11" Padding="10,4" Margin="0,0,4,0" Click="CopyClick"/>
                        <Button Content="Delete" FontSize="11" Padding="10,4" Margin="0,0,4,0" Click="DeleteClick"/>
                        <Border Width="28" Height="28" CornerRadius="14" Background="#50FFFFFF"
                                Cursor="Hand" MouseLeftButtonDown="CloseClick" VerticalAlignment="Center">
                            <Canvas Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Line X1="0" Y1="0" X2="8" Y2="8" Stroke="White" StrokeThickness="1.5"/>
                                <Line X1="8" Y1="0" X2="0" Y2="8" Stroke="White" StrokeThickness="1.5"/>
                            </Canvas>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
