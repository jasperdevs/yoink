<Window x:Class="Yoink.UI.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yoink - Viewer"
        WindowState="Maximized"
        WindowStyle="None"
        Background="#1A1A1A"
        KeyDown="OnKeyDown"
        MouseLeftButtonDown="OnClick">

    <Grid>
        <!-- Image -->
        <Image x:Name="ViewerImage" Stretch="Uniform" Margin="40"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- Top bar -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,16,0,0"
                Background="#CC1E1E1E" CornerRadius="10" Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="InfoText" Foreground="White" FontSize="12" Opacity="0.7"
                           VerticalAlignment="Center" Margin="8,0"/>
                <Button Content="Copy" FontSize="11" Padding="10,5" Margin="4,0" Click="CopyClick"
                        Background="#30FFFFFF" Foreground="White" BorderThickness="0"/>
                <Button Content="Delete" FontSize="11" Padding="10,5" Margin="4,0" Click="DeleteClick"
                        Background="#30FFFFFF" Foreground="White" BorderThickness="0"/>
                <Button Content="Close" FontSize="11" Padding="10,5" Margin="4,0,8,0" Click="CloseClick"
                        Background="#30FFFFFF" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
