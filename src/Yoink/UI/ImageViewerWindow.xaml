<Window x:Class="Yoink.UI.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yoink - Viewer"
        Width="900" Height="650"
        WindowStartupLocation="CenterOwner"
        ThemeMode="System"
        KeyDown="OnKeyDown">

    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="InfoText" FontSize="12" Opacity="0.5" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Copy" FontSize="11" Padding="12,5" Margin="0,0,4,0" Click="CopyClick"/>
                    <Button Content="Delete" FontSize="11" Padding="12,5" Margin="0,0,4,0" Click="DeleteClick"/>
                    <Button Content="Close" FontSize="11" Padding="12,5" Click="CloseClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Image -->
        <Border Grid.Row="1" Padding="24,0,24,24">
            <Border CornerRadius="8" ClipToBounds="True">
                <Image x:Name="ViewerImage" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
        </Border>
    </Grid>
</Window>
