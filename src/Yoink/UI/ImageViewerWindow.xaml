<Window x:Class="Yoink.UI.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yoink"
        Width="900" Height="650"
        WindowStartupLocation="CenterOwner"
        ThemeMode="System"
        KeyDown="OnKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="16,8,16,6">
            <Grid>
                <TextBlock x:Name="InfoText" FontSize="12" Opacity="0.4" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Copy" FontSize="11" Padding="10,4" Margin="0,0,4,0" Click="CopyClick"/>
                    <Button Content="Edit" FontSize="11" Padding="10,4" Margin="0,0,4,0" Click="EditClick"/>
                    <Button Content="Delete" FontSize="11" Padding="10,4" Click="DeleteClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Image -->
        <Border Grid.Row="1" Padding="20,0,20,20">
            <Border CornerRadius="8" ClipToBounds="True">
                <Image x:Name="ViewerImage" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
        </Border>
    </Grid>
</Window>
