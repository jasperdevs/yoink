<Window x:Class="Yoink.UI.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yoink"
        Width="820" Height="580"
        WindowStartupLocation="CenterOwner"
        ThemeMode="Dark"
        Background="#1C1C1C"
        KeyDown="OnKeyDown"
        ResizeMode="CanResize">

    <Grid>
        <!-- Full-bleed image -->
        <Border Margin="1" CornerRadius="0" ClipToBounds="True">
            <Image x:Name="ViewerImage" Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <!-- Top bar overlay with gradient fade -->
        <Border VerticalAlignment="Top" Padding="14,8,14,8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#B0000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <TextBlock x:Name="InfoText" FontSize="11" Opacity="0.6"
                           Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Copy" FontSize="11" Padding="10,4" Margin="0,0,4,0" Click="CopyClick"/>
                    <Button Content="Delete" FontSize="11" Padding="10,4" Click="DeleteClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
