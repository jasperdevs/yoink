<Window x:Class="Yoink.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yoink"
        Height="580" Width="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ThemeMode="System">

    <Window.Resources>
        <!-- Tab pill - monochrome, no accent color -->
        <Style x:Key="TabPill" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="14,7" CornerRadius="8" Cursor="Hand"
                                Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}"
                                       FontSize="13" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                       Opacity="0.4"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="1"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.35"/>
            <Setter Property="Margin" Value="2,0,0,8"/>
        </Style>

        <!-- Setting card - subtle, not washed out -->
        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Background" Value="#0AFFFFFF"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,20,24,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="Yoink" FontSize="22" FontWeight="Bold"/>
                    <Border Background="#15FFFFFF"
                            CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v0.1.0" FontSize="10" Opacity="0.35"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <RadioButton x:Name="SettingsTab" Content="Settings" GroupName="Tabs"
                                 IsChecked="True" Click="TabChanged" Style="{StaticResource TabPill}"/>
                    <RadioButton x:Name="HistoryTab" Content="History" GroupName="Tabs"
                                 Click="TabChanged" Margin="4,0,0,0" Style="{StaticResource TabPill}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">

            <!-- Settings -->
            <ScrollViewer x:Name="SettingsPanel" VerticalScrollBarVisibility="Auto" Padding="24,8,24,24">
                <StackPanel>

                    <TextBlock Text="CAPTURE" Style="{StaticResource SectionLabel}"/>

                    <!-- Hotkey card -->
                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Hotkey" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="HotkeyHint" Text="Click the box and press a new combo"
                                           FontSize="11" Opacity="0.4" Visibility="Collapsed"/>
                            </StackPanel>
                            <TextBox x:Name="HotkeyBox" Grid.Column="1" IsReadOnly="True"
                                     FontSize="13" Padding="12,7" MinWidth="130" TextAlignment="Center"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                     GotFocus="HotkeyBox_GotFocus"
                                     LostFocus="HotkeyBox_LostFocus"/>
                        </Grid>
                    </Border>

                    <!-- After capture card -->
                    <Border Style="{StaticResource SettingCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="After capture" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ComboBox x:Name="AfterCaptureCombo" Grid.Column="1" FontSize="12" Padding="10,6" MinWidth="160"
                                      SelectionChanged="AfterCaptureCombo_SelectionChanged">
                                <ComboBoxItem Content="Copy to clipboard"/>
                                <ComboBoxItem Content="Show preview"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <TextBlock Text="SAVING" Style="{StaticResource SectionLabel}" Margin="0,16,0,8"/>

                    <!-- Save to file card -->
                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <CheckBox x:Name="SaveToFileCheck" Content="Save screenshots to file" FontSize="13"
                                      Checked="SaveToFileCheck_Changed" Unchecked="SaveToFileCheck_Changed"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" x:Name="SaveDirPanel" Visibility="Collapsed">
                                <TextBox x:Name="SaveDirBox" IsReadOnly="True" FontSize="11" Padding="8,6" Width="300"/>
                                <Button Content="Browse" FontSize="11" Padding="10,6" Margin="8,0,0,0" Click="BrowseButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- History toggle card -->
                    <Border Style="{StaticResource SettingCard}">
                        <CheckBox x:Name="SaveHistoryCheck" Content="Save capture history" FontSize="13"
                                  Checked="SaveHistoryCheck_Changed" Unchecked="SaveHistoryCheck_Changed"/>
                    </Border>

                    <TextBlock Text="GENERAL" Style="{StaticResource SectionLabel}" Margin="0,16,0,8"/>

                    <!-- Start with Windows card -->
                    <Border Style="{StaticResource SettingCard}">
                        <CheckBox x:Name="StartWithWindowsCheck" Content="Launch on startup" FontSize="13"
                                  Checked="StartWithWindowsCheck_Changed" Unchecked="StartWithWindowsCheck_Changed"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- History -->
            <Grid x:Name="HistoryPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Empty state -->
                <TextBlock x:Name="HistoryEmptyText" Grid.Row="0" Text="No captures yet"
                           FontSize="14" Opacity="0.3" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>

                <!-- History grid -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="16,8,16,8">
                    <ItemsControl x:Name="HistoryItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="148" Margin="4" CornerRadius="8" ClipToBounds="True"
                                        Background="#0AFFFFFF" Cursor="Hand"
                                        MouseLeftButtonDown="HistoryItemClick"
                                        MouseRightButtonDown="HistoryItemRightClick"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="100"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Selection checkbox (visible in select mode) -->
                                        <CheckBox x:Name="SelectCheck" Grid.Row="0"
                                                  HorizontalAlignment="Left" VerticalAlignment="Top"
                                                  Margin="6,6,0,0" Visibility="Collapsed"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Click="HistorySelectToggle"/>
                                        <Image Grid.Row="0" Source="{Binding ThumbPath}" Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <StackPanel Grid.Row="1" Margin="8,6,8,8">
                                            <TextBlock Text="{Binding Dimensions}" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TimeAgo}" FontSize="10" Opacity="0.35"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Bottom bar -->
                <Border Grid.Row="1" Padding="16,8,16,12">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="HistoryCountText" FontSize="12" Opacity="0.35" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="SelectBtn" Content="Select" FontSize="11" Padding="10,5"
                                    Margin="0,0,4,0" Click="ToggleSelectMode"/>
                            <Button x:Name="DeleteSelectedBtn" Content="Delete selected" FontSize="11"
                                    Padding="10,5" Click="DeleteSelectedClick" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
