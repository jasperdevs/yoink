                    <!-- ImgBB settings -->
                    <controls:ProviderSection x:Name="ImgBBSettings" Header="IMGBB" IconSource="pack://application:,,,/Assets/imgbb_sq.png" Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Style="{StaticResource InlineTagChip}">
                                    <TextBlock Text="PNG" FontSize="9" Opacity="0.6"/>
                                </Border>
                                <Border Style="{StaticResource InlineTagChip}">
                                    <TextBlock Text="JPG" FontSize="9" Opacity="0.6"/>
                                </Border>
                                <Border Style="{StaticResource InlineTagChip}">
                                    <TextBlock Text="GIF" FontSize="9" Opacity="0.6"/>
                                </Border>
                                <TextBlock Text="  32MB max · Free" FontSize="10" Opacity="0.3" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="100 uploads/hour on free tier" FontSize="10" Opacity="0.25" Margin="0,0,0,8"/>

                            <TextBlock Text="API key" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                            <TextBox x:Name="ImgBBKeyBox" FontSize="11" Padding="7,4"
                                     ToolTip="Get a free API key at api.imgbb.com"
                                     Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                     TextChanged="ImgBBKeyBox_Changed"/>
                        </StackPanel>
                    </controls:ProviderSection>

                    <!-- Catbox info -->
                    <controls:ProviderSection x:Name="CatboxSettings" Header="CATBOX" IconSource="pack://application:,,,/Assets/catbox_sq.png" Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Style="{StaticResource InlineTagChip}">
                                    <TextBlock Text="Any file" FontSize="9" Opacity="0.6"/>
                                </Border>
                                <TextBlock Text="  200MB max · Free · Permanent" FontSize="10" Opacity="0.3" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="No rate limits · No account required · No configuration needed" FontSize="10" Opacity="0.25" Margin="0,0,0,4"/>
                        </StackPanel>
                    </controls:ProviderSection>

                    <!-- Litterbox info -->
                    <controls:ProviderSection x:Name="LitterboxSettings" Header="LITTERBOX" IconSource="pack://application:,,,/Assets/litterbox_sq.png" Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Style="{StaticResource InlineTagChip}">
                                    <TextBlock Text="Any file" FontSize="9" Opacity="0.6"/>
                                </Border>
                                <Border Style="{StaticResource InlineTagChipDanger}">
                                    <TextBlock Text="Expires 72h" FontSize="9" Foreground="#EF4444"/>
