                            <ComboBox x:Name="MicDeviceCombo" Grid.Column="1" FontSize="11" Padding="8,4" Margin="0,6,0,0"
                                      SelectionChanged="MicDeviceCombo_Changed"/>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <CheckBox x:Name="RecordDesktopAudioCheck" Content="Record desktop audio" FontSize="13"
                                      Checked="RecordDesktopAudioCheck_Changed" Unchecked="RecordDesktopAudioCheck_Changed"/>
