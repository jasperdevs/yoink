                                     Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                     TextChanged="GyazoTokenBox_Changed"/>
                        </StackPanel>
                    </controls:ProviderSection>

                    <!-- file.io info -->
                    <controls:ProviderSection x:Name="FileIoSettings" Header="FILE.IO" IconSource="pack://application:,,,/Assets/fileio_sq.png" Visibility="Collapsed">
                        <StackPanel>
