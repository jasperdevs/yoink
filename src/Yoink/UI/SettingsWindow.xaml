            <ScrollViewer x:Name="SettingsPanel" VerticalScrollBarVisibility="Auto" Padding="18,4,18,18">
                <StackPanel>
                    <TextBlock Text="General" Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="MuteSoundsCheck" Content="Mute capture sounds" FontSize="13"
                                      Checked="MuteSoundsCheck_Changed" Unchecked="MuteSoundsCheck_Changed"/>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sound pack" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="SoundPackCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="125"
                                          SelectionChanged="SoundPackCombo_SelectionChanged">
                                    <ComboBoxItem Content="Default"/>
                                    <ComboBoxItem Content="Soft"/>
                                    <ComboBoxItem Content="Retro"/>
                                </ComboBox>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <CheckBox x:Name="CrosshairGuidesCheck" Content="Show crosshair guides" FontSize="13"
                                      Checked="CrosshairGuidesCheck_Changed" Unchecked="CrosshairGuidesCheck_Changed"/>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Toast position" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="ToastPositionCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="125"
                                          SelectionChanged="ToastPositionCombo_SelectionChanged">
                                    <ComboBoxItem Content="Right"/>
                                    <ComboBoxItem Content="Left"/>
                                    <ComboBoxItem Content="Top Left"/>
                                    <ComboBoxItem Content="Top Right"/>
                                </ComboBox>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Toast duration" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="ToastDurationCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="125"
                                          SelectionChanged="ToastDurationCombo_SelectionChanged">
                                    <ComboBoxItem Content="1.5 seconds" Tag="1.5"/>
                                    <ComboBoxItem Content="2 seconds" Tag="2"/>
                                    <ComboBoxItem Content="2.5 seconds" Tag="2.5"/>
                                    <ComboBoxItem Content="3 seconds" Tag="3"/>
                                    <ComboBoxItem Content="4 seconds" Tag="4"/>
                                    <ComboBoxItem Content="5 seconds" Tag="5"/>
                                </ComboBox>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <CheckBox x:Name="AutoPinPreviewsCheck" Content="Auto-pin screenshot previews" FontSize="13"
                                      Checked="AutoPinPreviewsCheck_Changed" Unchecked="AutoPinPreviewsCheck_Changed"/>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <CheckBox x:Name="ShowImageSearchBarCheck" Content="Show image search bar on Images" FontSize="13"
                                      Checked="ShowImageSearchBarCheck_Changed" Unchecked="ShowImageSearchBarCheck_Changed"/>
                            <CheckBox x:Name="ShowImageSearchDiagnosticsCheck" Content="Show image search diagnostics" FontSize="13" Margin="0,6,0,0"
                                      Checked="ShowImageSearchDiagnosticsCheck_Changed" Unchecked="ShowImageSearchDiagnosticsCheck_Changed"/>
                            <CheckBox x:Name="AutoIndexImagesCheck" Content="Auto-index images for search" FontSize="13" Margin="0,6,0,0"
                                      Checked="AutoIndexImagesCheck_Changed" Unchecked="AutoIndexImagesCheck_Changed"/>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Image index cache" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="Clears screenshot OCR/search index and rebuilds it in the background." FontSize="11" Opacity="0.35" Margin="0,2,8,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button x:Name="ResetImageIndexesBtn" Grid.Column="1" Content="Reset image indexes" FontSize="11" Padding="10,5"
                                        Margin="8,0,0,0" Click="ResetImageIndexesBtn_Click"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <CheckBox x:Name="StartWithWindowsCheck" Content="Launch on startup" FontSize="13"
                                      Checked="StartWithWindowsCheck_Changed" Unchecked="StartWithWindowsCheck_Changed"/>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <Button Content="Export settings" FontSize="12" Padding="10,6"
                                        Margin="0,0,8,0" Click="ExportSettingsButton_Click"/>
                                <Button Content="Import settings" FontSize="12" Padding="10,6"
                                        Click="ImportSettingsButton_Click"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- About -->
            <ScrollViewer x:Name="AboutPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="18,4,18,18">
                <StackPanel>
                    <TextBlock Text="Updates" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="AutoUpdateCheck" Content="Automatically check for updates" FontSize="13"
                                      Checked="AutoUpdateCheck_Changed" Unchecked="AutoUpdateCheck_Changed"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="UpdateStatusText" Text="Checking for updates..." FontSize="12.5" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="UpdateDetailText" Text="" FontSize="11" Opacity="0.35" TextWrapping="Wrap" Margin="0,2,8,0"/>
                                </StackPanel>
                                <Button x:Name="CheckUpdatesButton" Grid.Column="1" Content="Check now" FontSize="11" Padding="10,5" Margin="8,0,0,0" Click="CheckUpdatesButton_Click"/>
                                <Button x:Name="DownloadUpdateButton" Grid.Column="2" Content="Open release" FontSize="11" Padding="10,5" Margin="6,0,0,0" Visibility="Collapsed" Click="DownloadUpdateButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="VersionText" FontSize="10.5" Opacity="0.22" HorizontalAlignment="Center" Margin="0,24,0,2">
                        <Run Text="Yoink"/>
                    </TextBlock>
                    <TextBlock HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Hyperlink NavigateUri="https://github.com/jasperdevs/yoink" RequestNavigate="Hyperlink_Navigate"
                                   Foreground="{DynamicResource ThemeAccentBrush}" FontSize="10.5">GitHub</Hyperlink>
                    </TextBlock>

                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,16,0,12"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Reset Settings" FontSize="12" Padding="10,6"
                                HorizontalAlignment="Left" Click="ResetSettingsButton_Click" Margin="0,0,10,0"/>
                        <Button Content="Uninstall Yoink" FontSize="12" Padding="10,6"
                                HorizontalAlignment="Left" Click="UninstallButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- History (merged: Screenshots + Text sub-tabs) -->
            <Grid x:Name="HistoryPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Category dropdown + actions -->
                <Border Grid.Row="0" Padding="10,6,10,6">
                    <StackPanel>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel x:Name="ReindexAllProgressPanel" Orientation="Horizontal" VerticalAlignment="Center"
                                            Margin="0,0,8,0" Visibility="Collapsed">
                                    <ProgressBar x:Name="ReindexAllProgressBar" Width="72" Height="4" IsIndeterminate="True" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ReindexAllProgressText" Text="Indexing..." FontSize="10.5" Opacity="0.56" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <Button x:Name="SelectBtn" Content="Select" FontSize="10.5" Padding="10,3"
                                         Margin="0,0,4,0" Click="ToggleSelectMode"/>
                                <Button x:Name="DeleteAllBtn" Content="Clear all" FontSize="10.5" Padding="10,3"
                                        Click="DeleteAllClick"/>
                                <Button x:Name="DeleteSelectedBtn" Content="Delete selected" FontSize="10.5"
                                         Padding="10,3" Margin="4,0,0,0" Visibility="Collapsed" Click="DeleteSelectedClick"/>
                            </StackPanel>
                            <ComboBox x:Name="HistoryCategoryCombo" FontSize="12" Padding="8,5" MinWidth="130"
                                      VerticalAlignment="Center" SelectionChanged="HistoryCategoryCombo_Changed"
                                      PreviewMouseLeftButtonDown="HistoryCategoryCombo_PreviewMouseLeftButtonDown">
                                <ComboBoxItem Content="Images" IsSelected="True"/>
                                <ComboBoxItem Content="Text"/>
                                <ComboBoxItem Content="Videos/GIFs"/>
                                <ComboBoxItem Content="Colors"/>
                                <ComboBoxItem Content="Stickers"/>
                            </ComboBox>
                        </DockPanel>

                        <Grid x:Name="ImageSearchRow" Margin="0,8,0,0" Visibility="Visible">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                            <Border Background="{DynamicResource ThemeInputBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                    BorderThickness="1" CornerRadius="7" Padding="10,6">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   VerticalAlignment="Center" Opacity="0.35"/>
                                        <Grid Grid.Column="1" Margin="8,0,0,0">
                                            <TextBox x:Name="ImageSearchBox" BorderThickness="0" Background="Transparent"
                                                     FontSize="12" Padding="0" VerticalContentAlignment="Center"
                                                     TextChanged="ImageSearchBox_TextChanged"
                                                     PreviewKeyDown="ImageSearchBox_PreviewKeyDown"
                                                     GotKeyboardFocus="ImageSearchBox_FocusChanged"
                                                     LostKeyboardFocus="ImageSearchBox_FocusChanged"/>
                                            <TextBlock x:Name="ImageSearchPlaceholder" Text="Search screenshots, OCR text, filenames, or semantic matches..."
                                                       FontSize="12" Opacity="0.28" VerticalAlignment="Center"
                                                       IsHitTestVisible="False" Margin="0,0,0,0"/>
                                        </Grid>
                                    </Grid>

                                    <DockPanel Margin="22,10,0,0" LastChildFill="False">
                                        <TextBlock Text="Filters" FontSize="10.5" Opacity="0.42" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock x:Name="ImageSearchFiltersSummaryText" FontSize="10.5" Opacity="0.62" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Button x:Name="ImageSearchFiltersBtn" Content="Edit filters" FontSize="10.5" Padding="10,3"
                                                DockPanel.Dock="Right" Click="ImageSearchFiltersBtn_Click">
                                            <Button.ContextMenu>
                                                <ContextMenu x:Name="ImageSearchFiltersMenu" Placement="Bottom">
                                                    <MenuItem x:Name="ImageSearchFileNameCheck" Header="File name" IsCheckable="True"
                                                              Checked="ImageSearchSourcesCheck_Changed" Unchecked="ImageSearchSourcesCheck_Changed"/>
                                                    <MenuItem x:Name="ImageSearchOcrCheck" Header="OCR text" IsCheckable="True"
                                                              Checked="ImageSearchSourcesCheck_Changed" Unchecked="ImageSearchSourcesCheck_Changed"/>
                                                    <MenuItem x:Name="ImageSearchSemanticCheck" Header="Semantic" IsCheckable="True"
                                                              Checked="ImageSearchSourcesCheck_Changed" Unchecked="ImageSearchSourcesCheck_Changed"/>
                                                    <Separator/>
                                                    <MenuItem x:Name="ImageSearchExactMatchCheck" Header="Exact match" IsCheckable="True"
                                                              ToolTip="Require exact phrase/token matches and skip semantic refine"
                                                              Checked="ImageSearchExactMatchCheck_Changed" Unchecked="ImageSearchExactMatchCheck_Changed"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                    </DockPanel>
                                    <StackPanel Orientation="Horizontal" Margin="22,6,0,0" VerticalAlignment="Center">
                                        <ProgressBar x:Name="ImageSearchLoadingBar" Width="110" Height="3"
                                                     IsIndeterminate="True" Visibility="Collapsed"
                                                     Margin="0,0,8,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Images history -->
                <ScrollViewer x:Name="ImagesPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,2,10,4"
                              ScrollChanged="HistoryPanel_ScrollChanged">
                    <StackPanel x:Name="HistoryStack"/>
                </ScrollViewer>

                <!-- Videos / GIF history -->
                <ScrollViewer x:Name="GifsPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,2,10,4"
                              ScrollChanged="GifPanel_ScrollChanged"
                              Visibility="Collapsed">
                    <StackPanel x:Name="GifStack"/>
                </ScrollViewer>

                <!-- Text history -->
                <ScrollViewer x:Name="TextPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="14,2,14,14" Visibility="Collapsed">
                    <StackPanel x:Name="OcrStack"/>
                </ScrollViewer>

                <!-- Color history -->
                <ScrollViewer x:Name="ColorsPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="14,2,14,14" Visibility="Collapsed">
                    <WrapPanel x:Name="ColorStack"/>
                </ScrollViewer>

                <!-- Sticker history -->
                <ScrollViewer x:Name="StickersPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="10,2,10,4" Visibility="Collapsed"
                              ScrollChanged="StickerPanel_ScrollChanged">
                    <StackPanel x:Name="StickerStack"/>
                </ScrollViewer>

                <!-- Empty states -->
                <StackPanel x:Name="HistoryEmptyText" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="No items" FontSize="16" FontFamily="Segoe UI Variable Text" FontWeight="SemiBold" HorizontalAlignment="Center" Opacity="0.1"/>
                    <TextBlock x:Name="HistoryEmptyLabel" Text="No captures yet" FontSize="13" FontFamily="Segoe UI Variable Text"
                               Opacity="0.2" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Bottom bar -->
                <Border Grid.Row="2" Padding="14,4,14,8">
                    <DockPanel LastChildFill="False">
                        <TextBlock x:Name="HistoryCountText" FontSize="11" Opacity="0.25" VerticalAlignment="Center"
                                   DockPanel.Dock="Left"/>
                        <TextBlock x:Name="HistorySearchStatusText" FontSize="11" Opacity="0.24" VerticalAlignment="Center"
                                   HorizontalAlignment="Right" Margin="12,0,0,0"/>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Uploads -->
            <ScrollViewer x:Name="UploadsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="18,4,18,18">
                <StackPanel>
                    <Border Padding="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="UploadImagesSubTab" Content="Images" GroupName="UploadSub"
                                         IsChecked="True" Click="UploadSubTabChanged" Style="{StaticResource SubTab}"/>
                            <RadioButton x:Name="UploadStickersSubTab" Content="Stickers" GroupName="UploadSub"
                                         Click="UploadSubTabChanged" Margin="2,0,0,0" Style="{StaticResource SubTab}"/>
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="ImageUploadsPanel">
                    <TextBlock Text="Destination" Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Upload service" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="UploadDestCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="145"
                                          SelectionChanged="UploadDestCombo_Changed">
                                    <ComboBoxItem Content="None"/>
                                    <ComboBoxItem Content="Imgur"/>
                                    <ComboBoxItem Content="ImgBB"/>
                                    <ComboBoxItem Content="Catbox"/>
                                    <ComboBoxItem Content="Litterbox (temp)"/>
                                    <ComboBoxItem Content="Gyazo"/>
                                    <ComboBoxItem Content="file.io"/>
                                    <ComboBoxItem Content="Uguu (temp)"/>
                                    <ComboBoxItem Content="transfer.sh"/>
                                    <ComboBoxItem Content="Dropbox"/>
                                    <ComboBoxItem Content="Google Drive"/>
                                    <ComboBoxItem Content="OneDrive"/>
                                    <ComboBoxItem Content="Azure Blob"/>
                                    <ComboBoxItem Content="GitHub"/>
                                    <ComboBoxItem Content="Immich"/>
                                    <ComboBoxItem Content="FTP"/>
                                    <ComboBoxItem Content="SFTP"/>
                                    <ComboBoxItem Content="WebDAV"/>
                                    <ComboBoxItem Content="S3 / R2 / B2"/>
                                    <ComboBoxItem Content="Custom HTTP"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Imgur settings -->
                    <controls:ProviderSection x:Name="ImgurSettings" Header="IMGUR" IconSource="pack://application:,,,/Assets/imgur_sq.png" Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Style="{StaticResource InlineTagChip}">
                                    <TextBlock Text="PNG" FontSize="9" Opacity="0.6"/>
                                </Border>
                                <Border Style="{StaticResource InlineTagChip}">
                                    <TextBlock Text="JPG" FontSize="9" Opacity="0.6"/>
                                </Border>
                                <Border Style="{StaticResource InlineTagChip}">
                                    <TextBlock Text="GIF" FontSize="9" Opacity="0.6"/>
                                </Border>
                                <TextBlock Text="  20MB images · 200MB GIF · Free" FontSize="10" Opacity="0.3" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="1,250 uploads/day anonymous · 12,500/day with account" FontSize="10" Opacity="0.25" Margin="0,0,0,8"/>

                            <TextBlock Text="Client ID" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                            <TextBox x:Name="ImgurClientIdBox" FontSize="11" Padding="7,4"
                                     ToolTip="Optional — has built-in default for anonymous uploads"
                                     Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                     TextChanged="ImgurClientIdBox_Changed"/>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <TextBlock Text="Access token" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                            <TextBox x:Name="ImgurTokenBox" FontSize="11" Padding="7,4"
                                     ToolTip="Optional — for uploading to your Imgur account"
                                     Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                     TextChanged="ImgurTokenBox_Changed"/>
