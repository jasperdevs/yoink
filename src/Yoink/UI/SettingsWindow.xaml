                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="FtpSettings" Visibility="Collapsed">
                        <TextBlock Text="FTP" Style="{StaticResource SectionLabel}" Margin="4,16,0,6"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="FTP URL" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBox x:Name="FtpUrlBox" FontSize="11" Padding="7,4" TextChanged="FtpUrlBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <TextBlock Text="Username" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="FtpUsernameBox" FontSize="11" Padding="7,4" TextChanged="FtpUsernameBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <TextBlock Text="Password" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="FtpPasswordBox" FontSize="11" Padding="7,4" TextChanged="FtpPasswordBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <TextBlock Text="Public URL base (optional)" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="FtpPublicUrlBox" FontSize="11" Padding="7,4" TextChanged="FtpPublicUrlBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="SftpSettings" Visibility="Collapsed">
                        <TextBlock Text="SFTP" Style="{StaticResource SectionLabel}" Margin="4,16,0,6"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Host" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBox x:Name="SftpHostBox" FontSize="11" Padding="7,4" TextChanged="SftpHostBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <TextBlock Text="Port" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpPortBox" FontSize="11" Padding="7,4" TextChanged="SftpPortBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <TextBlock Text="Username" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpUsernameBox" FontSize="11" Padding="7,4" TextChanged="SftpUsernameBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <TextBlock Text="Password" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpPasswordBox" FontSize="11" Padding="7,4" TextChanged="SftpPasswordBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <TextBlock Text="Remote path" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpRemotePathBox" FontSize="11" Padding="7,4" TextChanged="SftpRemotePathBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <TextBlock Text="Public URL base (optional)" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpPublicUrlBox" FontSize="11" Padding="7,4" TextChanged="SftpPublicUrlBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="WebDavSettings" Visibility="Collapsed">
                        <TextBlock Text="WEBDAV" Style="{StaticResource SectionLabel}" Margin="4,16,0,6"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="WebDAV URL" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBox x:Name="WebDavUrlBox" FontSize="11" Padding="7,4" TextChanged="WebDavUrlBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <TextBlock Text="Username" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="WebDavUsernameBox" FontSize="11" Padding="7,4" TextChanged="WebDavUsernameBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <TextBlock Text="Password" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="WebDavPasswordBox" FontSize="11" Padding="7,4" TextChanged="WebDavPasswordBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <TextBlock Text="Public URL base (optional)" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="WebDavPublicUrlBox" FontSize="11" Padding="7,4" TextChanged="WebDavPublicUrlBox_Changed" Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Custom HTTP settings -->
                    <StackPanel x:Name="CustomUploadSettings" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="4,16,0,6">
                            <Border Width="16" Height="16" CornerRadius="3" Background="#5865F2" Margin="0,0,6,0" VerticalAlignment="Center">
                                <TextBlock Text="&#x2B06;" FontSize="9" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                            </Border>
                            <TextBlock Text="CUSTOM HTTP" Style="{StaticResource SectionLabel}" Margin="0"/>
                        </StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Upload URL" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBox x:Name="CustomUrlBox" FontSize="11" Padding="7,4"
                                         Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"
                                         TextChanged="CustomUrlBox_Changed"/>

                                <Border Height="1" Background="#0AFFFFFF" Margin="0,10,0,10"/>

                                <TextBlock Text="File form field name" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBox x:Name="CustomFieldBox" FontSize="11" Padding="7,4" Text="file"
                                         Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"
                                         TextChanged="CustomFieldBox_Changed"/>

                                <Border Height="1" Background="#0AFFFFFF" Margin="0,10,0,10"/>

                                <TextBlock Text="Response JSON path to URL" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBlock Text="Dot-separated path, e.g. data.url or just url" FontSize="11" Opacity="0.25" Margin="0,0,0,4"/>
                                <TextBox x:Name="CustomJsonPathBox" FontSize="11" Padding="7,4" Text="url"
                                         Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"
                                         TextChanged="CustomJsonPathBox_Changed"/>

                                <Border Height="1" Background="#0AFFFFFF" Margin="0,10,0,10"/>

                                <TextBlock Text="Custom headers" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBlock Text="One per line, format: Name: Value" FontSize="11" Opacity="0.25" Margin="0,0,0,4"/>
                                <TextBox x:Name="CustomHeadersBox" FontSize="11" Padding="7,4" AcceptsReturn="True"
                                         Height="70" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                         Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"
                                         TextChanged="CustomHeadersBox_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="AUTO-UPLOAD" Style="{StaticResource SectionLabel}" Margin="4,16,0,6"/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="AutoUploadScreenshotsCheck" Content="Auto-upload screenshots" FontSize="13"
                                      Checked="AutoUploadScreenshotsCheck_Changed" Unchecked="AutoUploadScreenshotsCheck_Changed"/>
                            <TextBlock Text="Uploads after every screenshot capture and attaches the link to the preview/history item" FontSize="11" Opacity="0.25" Margin="0,2,0,0" TextWrapping="Wrap"/>

                            <Border Height="1" Background="#0AFFFFFF" Margin="0,10,0,10"/>

                            <CheckBox x:Name="AutoUploadGifsCheck" Content="Auto-upload GIFs" FontSize="13"
                                      Checked="AutoUploadGifsCheck_Changed" Unchecked="AutoUploadGifsCheck_Changed"/>
                            <TextBlock Text="Uploads after every GIF recording and attaches the link to the preview/history item" FontSize="11" Opacity="0.25" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Test upload -->
                    <Border Style="{StaticResource Card}" Margin="0,14,0,0" x:Name="TestUploadCard" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Test your upload configuration by sending a tiny 1x1 pixel image." FontSize="11" Opacity="0.35" Margin="0,0,0,8"/>
                            <Button x:Name="TestUploadBtn" Content="Test Upload" FontSize="12" Padding="12,6"
                                    HorizontalAlignment="Left" Click="TestUpload_Click" Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
    </Border>
    </Border>
</Window>
