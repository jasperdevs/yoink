<Window x:Class="Yoink.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Yoink.UI.Controls"
        Title="Yoink"
        Height="660" Width="720"
        MinHeight="660" MinWidth="720"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Icon="pack://application:,,,/yoink.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" CornerRadius="12"
                      ResizeBorderThickness="8" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#FFF0F0F0"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#FF9A9A9A"/>
        <SolidColorBrush x:Key="ThemeMutedBrush" Color="#FF686868"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="ThemeTabActiveBrush" Color="#18FFFFFF"/>
        <SolidColorBrush x:Key="ThemeTabHoverBrush" Color="#0EFFFFFF"/>
        <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ThemeWindowBorderBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ThemeSeparatorBrush" Color="#0CFFFFFF"/>

        <Style x:Key="TabPill" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="16,7" CornerRadius="7" Cursor="Hand" Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="12.5"
                                       FontFamily="Segoe UI Variable Text"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.55"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="1"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubTab" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="12,5" CornerRadius="6" Cursor="Hand" Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="11.5"
                                       FontFamily="Segoe UI Variable Text"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.92"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="Medium"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tb" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Opacity" Value="0.52"/>
            <Setter Property="Margin" Value="4,0,0,6"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Bd" Padding="14,9" CornerRadius="7" Cursor="Hand" Background="Transparent"
                                    Margin="4,1">
                                <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="12.5"
                                           FontFamily="Segoe UI Variable Text"
                                           Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.55"/>
                            </Border>
                            <Border x:Name="Accent" Width="3" Height="16" CornerRadius="1.5"
                                    Background="{DynamicResource ThemeAccentBrush}" Opacity="0"
                                    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="1,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="1"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Accent" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Opacity" Value="0.3"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource ChromeButtonBase}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeWindowBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="InlineTagChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style x:Key="InlineTagChipDanger" TargetType="Border" BasedOn="{StaticResource InlineTagChip}">
            <Setter Property="Background" Value="#30EF4444"/>
        </Style>

        <Style x:Key="ProviderIconFrame" TargetType="Border">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="#16FFFFFF"/>
            <Setter Property="BorderBrush" Value="#28FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ProviderIconImage" TargetType="Image">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style TargetType="{x:Type controls:ProviderSection}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:ProviderSection}">
                        <StackPanel>
                            <Grid Margin="4,16,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="IconFrame" Style="{StaticResource ProviderIconFrame}">
                                    <Image Source="{TemplateBinding IconSource}" Style="{StaticResource ProviderIconImage}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="{TemplateBinding Header}" Style="{StaticResource SectionLabel}" Margin="0"/>
                                <ContentPresenter Grid.Column="2" Content="{TemplateBinding HeaderExtras}" VerticalAlignment="Center"/>
                            </Grid>
                            <Border Style="{StaticResource Card}">
                                <ContentPresenter Content="{TemplateBinding Content}"/>
                            </Border>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IconSource, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                <Setter TargetName="IconFrame" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IconSource, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                <Setter TargetName="IconFrame" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hotkey input textbox -->
        <Style x:Key="HotkeyBox" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small clear button -->
        <Style x:Key="ClearBtn" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="5" Background="{DynamicResource ThemeTabHoverBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

        <Border Margin="1" CornerRadius="12">
    <Border x:Name="OuterBorder" CornerRadius="12" ClipToBounds="True" Background="#1F1F1F"
            BorderBrush="#12FFFFFF" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border x:Name="TitleBarBorder" Grid.Row="0" Padding="16,8,0,0" Background="#1A1A1A"
                CornerRadius="11,11,0,0"
                MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/yoink.ico" Width="16" Height="16"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.85"/>
                    <TextBlock x:Name="TitleText" Text="Yoink" FontSize="12.5" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable Display"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.85" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Width="40" Height="34" CornerRadius="0,11,0,0" Cursor="Hand" Background="Transparent"
                        MouseLeftButtonDown="CloseBtn_Click" MouseEnter="TitleBtn_Enter" MouseLeave="TitleBtn_Leave"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,0,0">
                    <Canvas Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Line X1="0" Y1="0" X2="12" Y2="12" Stroke="{DynamicResource ThemeTextSecondaryBrush}" StrokeThickness="1.4"/>
                        <Line X1="12" Y1="0" X2="0" Y2="12" Stroke="{DynamicResource ThemeTextSecondaryBrush}" StrokeThickness="1.4"/>
                    </Canvas>
                </Border>
            </Grid>
        </Border>

        <!-- Sidebar + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar navigation -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource ThemeSeparatorBrush}" BorderThickness="0,0,1,0"
                    Padding="6,10,6,10">
                <StackPanel>
                    <RadioButton x:Name="SettingsTab" Content="General" GroupName="Main"
                                 IsChecked="True" Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <RadioButton x:Name="HotkeysTab" Content="Tools" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <RadioButton x:Name="CaptureTab" Content="Capture" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <RadioButton x:Name="RecordingTab" Content="Recording" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="8,6,8,6"/>
                    <RadioButton x:Name="HistoryTab" Content="History" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <RadioButton x:Name="UploadsTab" Content="Uploads" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="8,6,8,6"/>
                    <RadioButton x:Name="AboutTab" Content="About" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                </StackPanel>
            </Border>

            <!-- Content area -->
            <Grid Grid.Column="1">


            <!-- Tools (unified hotkeys + toolbar) -->
            <ScrollViewer x:Name="HotkeysPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="18,4,18,18">
                <StackPanel>
                    <TextBlock Text="Tools" Style="{StaticResource SectionLabel}"/>
                    <CheckBox x:Name="ShowToolNumberBadgesCheck" Visibility="Collapsed"
                              Checked="ShowToolNumberBadgesCheck_Changed" Unchecked="ShowToolNumberBadgesCheck_Changed"/>
                    <StackPanel x:Name="ToolTogglePanel"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Capture + Saving -->
            <ScrollViewer x:Name="CapturePanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="18,4,18,18">
                <StackPanel>
                    <TextBlock Text="Capture" Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Default capture tool" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox x:Name="DefaultCaptureModeCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="145"
                                      SelectionChanged="DefaultCaptureModeCombo_SelectionChanged">
                                <ComboBoxItem Content="Rectangle"/>
                                <ComboBoxItem Content="Freeform"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <CheckBox x:Name="ShowCursorCheck" Content="Show cursor in captures" FontSize="13"
                                  Checked="ShowCursorCheck_Changed" Unchecked="ShowCursorCheck_Changed"/>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Window detection" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox x:Name="WindowDetectionCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="145"
                                      SelectionChanged="WindowDetectionCombo_SelectionChanged">
                                <ComboBoxItem Content="Off"/>
                                <ComboBoxItem Content="Windows only"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="After capture" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox x:Name="AfterCaptureCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="145"
                                      SelectionChanged="AfterCaptureCombo_SelectionChanged">
                                <ComboBoxItem Content="Copy to clipboard"/>
                                <ComboBoxItem Content="Show preview"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Capture delay" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CaptureDelayCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="145"
                                      SelectionChanged="CaptureDelayCombo_SelectionChanged">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="3 seconds"/>
                                <ComboBoxItem Content="5 seconds"/>
                                <ComboBoxItem Content="10 seconds"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <TextBlock Text="Saving" Style="{StaticResource SectionLabel}" Margin="4,16,0,6"/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="SaveToFileCheck" Content="Save screenshots to file" FontSize="13"
                                      Checked="SaveToFileCheck_Changed" Unchecked="SaveToFileCheck_Changed"/>
                            <CheckBox x:Name="AskFileNameCheck" Content="Ask for file name every time" FontSize="13" Margin="0,8,0,0"
                                      Checked="AskFileNameCheck_Changed" Unchecked="AskFileNameCheck_Changed"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Default format" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CaptureFormatCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="120"
                                          SelectionChanged="CaptureFormatCombo_SelectionChanged">
                                    <ComboBoxItem Content="PNG"/>
                                    <ComboBoxItem Content="JPG"/>
                                    <ComboBoxItem Content="BMP"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="JpegQualityPanel" Margin="0,10,0,0" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="JPG quality" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="JpegQualityCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="120"
                                          SelectionChanged="JpegQualityCombo_SelectionChanged">
                                    <ComboBoxItem Content="100 - Best" Tag="100"/>
                                    <ComboBoxItem Content="90 - High" Tag="90"/>
                                    <ComboBoxItem Content="85 - Balanced" Tag="85"/>
                                    <ComboBoxItem Content="75 - Smaller" Tag="75"/>
                                    <ComboBoxItem Content="60 - Tiny" Tag="60"/>
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Max image size" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CaptureSizeCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="120"
                                          SelectionChanged="CaptureSizeCombo_SelectionChanged">
                                    <ComboBoxItem Content="Original" Tag="0"/>
                                    <ComboBoxItem Content="2160p" Tag="2160"/>
                                    <ComboBoxItem Content="1440p" Tag="1440"/>
                                    <ComboBoxItem Content="1080p" Tag="1080"/>
                                    <ComboBoxItem Content="720p" Tag="720"/>
                                    <ComboBoxItem Content="480p" Tag="480"/>
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="OCR language" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="OcrLanguageCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="145"
                                          SelectionChanged="OcrLanguageCombo_SelectionChanged"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" x:Name="SaveDirPanel" Visibility="Collapsed">
                                <TextBox x:Name="SaveDirBox" IsReadOnly="True" FontSize="11" Padding="7,4" Width="280"
                                          Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <Button Content="Browse" Margin="5,0,0,0" Click="BrowseButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="SaveHistoryCheck" Content="Save capture history" FontSize="13"
                                      Checked="SaveHistoryCheck_Changed" Unchecked="SaveHistoryCheck_Changed"/>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Auto-clear" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="HistoryRetentionCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="120"
                                          SelectionChanged="HistoryRetentionCombo_SelectionChanged">
                                    <ComboBoxItem Content="Never"/>
                                    <ComboBoxItem Content="1 day"/>
                                    <ComboBoxItem Content="7 days"/>
                                    <ComboBoxItem Content="30 days"/>
                                    <ComboBoxItem Content="3 months"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Recording -->
            <ScrollViewer x:Name="RecordingPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="18,4,18,18">
                <StackPanel>
                    <TextBlock Text="Recording" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Format" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="RecordingFormatCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="125"
                                          SelectionChanged="RecordingFormatCombo_Changed">
                                    <ComboBoxItem Content="GIF"/><ComboBoxItem Content="MP4"/><ComboBoxItem Content="WebM"/><ComboBoxItem Content="MKV"/>
                                </ComboBox>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Quality" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="RecordingQualityCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="125"
                                          SelectionChanged="RecordingQualityCombo_Changed">
                                    <ComboBoxItem Content="Original"/><ComboBoxItem Content="1080p"/><ComboBoxItem Content="720p"/><ComboBoxItem Content="480p"/>
                                </ComboBox>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="FPS" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="RecordingFpsCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="125"
                                          SelectionChanged="RecordingFpsCombo_Changed">
                                    <ComboBoxItem Content="15" Tag="15"/><ComboBoxItem Content="24" Tag="24"/>
                                    <ComboBoxItem Content="30" Tag="30"/><ComboBoxItem Content="60" Tag="60"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="VideoOnlySettings" Style="{StaticResource Card}" Margin="0,3,0,0">
                        <StackPanel>
                            <CheckBox x:Name="RecordMicCheck" Content="Record microphone" FontSize="13"
