                                <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Bucket" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                        <TextBox x:Name="S3BucketBox" FontSize="11" Padding="7,4"
                                                 Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                                 TextChanged="S3BucketBox_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Region" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                        <TextBox x:Name="S3RegionBox" FontSize="11" Padding="7,4" Text="auto"
                                                 Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                                 TextChanged="S3RegionBox_Changed"/>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                                <TextBlock Text="Access Key" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBox x:Name="S3AccessKeyBox" FontSize="11" Padding="7,4"
                                         Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                         TextChanged="S3AccessKeyBox_Changed"/>

                                <TextBlock Text="Secret Key" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="S3SecretKeyBox" FontSize="11" Padding="7,4"
                                         Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                         TextChanged="S3SecretKeyBox_Changed"/>

                                <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                                <TextBlock Text="Public URL (optional)" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBox x:Name="S3PublicUrlBox" FontSize="11" Padding="7,4"
