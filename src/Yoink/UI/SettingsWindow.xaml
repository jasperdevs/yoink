<Window x:Class="Yoink.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yoink"
        Height="580" Width="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Foreground="White"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Icon="pack://application:,,,/yoink.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" CornerRadius="0"
                      ResizeBorderThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TabPill" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="14,6" CornerRadius="6" Cursor="Hand" Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="12"
                                       Foreground="White" Opacity="0.4"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="1"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0CFFFFFF"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubTab" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="10,4" CornerRadius="5" Cursor="Hand" Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="11" Foreground="White" Opacity="0.35"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tb" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.35"/>
            <Setter Property="Margin" Value="4,0,0,6"/>

        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="Background" Value="#252525"/>
        </Style>

        <!-- Dark theme textbox for hotkeys -->
        <Style x:Key="HotkeyBox" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="115"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="BorderBrush" Value="#18FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small clear button -->
        <Style x:Key="ClearBtn" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#60FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="5" Background="#10FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="16" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.5" Color="Black"/>
        </Border.Effect>
    <Border x:Name="OuterBorder" CornerRadius="12" ClipToBounds="True" Background="#1C1C1C"
            BorderBrush="#15FFFFFF" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border x:Name="TitleBarBorder" Grid.Row="0" Padding="14,10,8,10" Background="#161616"
                CornerRadius="11,11,0,0"
                MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock x:Name="TitleText" Text="Yoink" FontSize="12" FontWeight="SemiBold" Foreground="White"
                           Opacity="0.8" VerticalAlignment="Center"/>
                <Border Width="32" Height="28" CornerRadius="6" Cursor="Hand" Background="Transparent"
                        MouseLeftButtonDown="CloseBtn_Click" MouseEnter="TitleBtn_Enter" MouseLeave="TitleBtn_Leave"
                        HorizontalAlignment="Right">
                    <Canvas Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Line X1="0" Y1="0" X2="10" Y2="10" Stroke="#AAFFFFFF" StrokeThickness="1.5"/>
                        <Line X1="10" Y1="0" X2="0" Y2="10" Stroke="#AAFFFFFF" StrokeThickness="1.5"/>
                    </Canvas>
                </Border>
            </Grid>
        </Border>

        <!-- Main tabs -->
        <Border Grid.Row="1" Padding="16,6,16,6">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="SettingsTab" Content="Settings" GroupName="Main"
                             IsChecked="True" Click="TabChanged" Style="{StaticResource TabPill}"/>
                <RadioButton x:Name="HistoryTab" Content="History" GroupName="Main"
                             Click="TabChanged" Margin="2,0,0,0" Style="{StaticResource TabPill}"/>
                <RadioButton x:Name="UploadsTab" Content="Uploads" GroupName="Main"
                             Click="TabChanged" Margin="2,0,0,0" Style="{StaticResource TabPill}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">

            <!-- Settings -->
            <ScrollViewer x:Name="SettingsPanel" VerticalScrollBarVisibility="Auto" Padding="18,4,18,18">
                <StackPanel>
                    <TextBlock Text="HOTKEYS" Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <!-- Screenshot hotkey -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Screenshot" FontSize="13" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBox x:Name="HotkeyBox" Style="{StaticResource HotkeyBox}"
                                             PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                             GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus"/>
                                    <Button Content="X" Style="{StaticResource ClearBtn}" Click="ClearCaptureHotkey_Click"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#0AFFFFFF" Margin="0,10,0,10"/>

                            <!-- OCR hotkey -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Text capture (OCR)" FontSize="13"/>
                                    <TextBlock Text="Copies text from screen" FontSize="11" Opacity="0.25"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBox x:Name="OcrHotkeyBox" Style="{StaticResource HotkeyBox}"
                                             PreviewKeyDown="OcrHotkeyBox_PreviewKeyDown"
                                             GotFocus="OcrHotkeyBox_GotFocus" LostFocus="OcrHotkeyBox_LostFocus"/>
                                    <Button Content="X" Style="{StaticResource ClearBtn}" Click="ClearOcrHotkey_Click"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#0AFFFFFF" Margin="0,10,0,10"/>

                            <!-- Color picker hotkey -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Color picker" FontSize="13"/>
                                    <TextBlock Text="Pick color, copies hex" FontSize="11" Opacity="0.25"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBox x:Name="PickerHotkeyBox" Style="{StaticResource HotkeyBox}"
                                             PreviewKeyDown="PickerHotkeyBox_PreviewKeyDown"
                                             GotFocus="PickerHotkeyBox_GotFocus" LostFocus="PickerHotkeyBox_LostFocus"/>
                                    <Button Content="X" Style="{StaticResource ClearBtn}" Click="ClearPickerHotkey_Click"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#0AFFFFFF" Margin="0,10,0,10"/>

                            <!-- Scanner hotkey -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="QR/barcode scanner" FontSize="13"/>
                                    <TextBlock Text="Optional" FontSize="11" Opacity="0.25"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBox x:Name="ScanHotkeyBox" Style="{StaticResource HotkeyBox}"
                                             PreviewKeyDown="ScanHotkeyBox_PreviewKeyDown"
                                             GotFocus="ScanHotkeyBox_GotFocus" LostFocus="ScanHotkeyBox_LostFocus"/>
                                    <Button Content="X" Style="{StaticResource ClearBtn}" Click="ClearScanHotkey_Click"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#0AFFFFFF" Margin="0,10,0,10"/>

                            <!-- GIF recording hotkey -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Record GIF" FontSize="13"/>
                                    <TextBlock Text="Optional" FontSize="11" Opacity="0.25"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBox x:Name="GifHotkeyBox" Style="{StaticResource HotkeyBox}"
                                             PreviewKeyDown="GifHotkeyBox_PreviewKeyDown"
                                             GotFocus="GifHotkeyBox_GotFocus" LostFocus="GifHotkeyBox_LostFocus"/>
                                    <Button Content="X" Style="{StaticResource ClearBtn}" Click="ClearGifHotkey_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="CAPTURE" Style="{StaticResource SectionLabel}" Margin="4,16,0,6"/>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Default capture tool" FontSize="13"/>
                                <TextBlock Text="What the main screenshot hotkey opens" FontSize="11" Opacity="0.25"/>
                            </StackPanel>
                            <ComboBox x:Name="DefaultCaptureModeCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="145"
                                      SelectionChanged="DefaultCaptureModeCombo_SelectionChanged">
                                <ComboBoxItem Content="Rectangle"/>
                                <ComboBoxItem Content="Freeform"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="After capture" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox x:Name="AfterCaptureCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="145"
                                      SelectionChanged="AfterCaptureCombo_SelectionChanged">
                                <ComboBoxItem Content="Copy to clipboard"/>
                                <ComboBoxItem Content="Show preview"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <TextBlock Text="SAVING" Style="{StaticResource SectionLabel}" Margin="4,16,0,6"/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="SaveToFileCheck" Content="Save screenshots to file" FontSize="13"
                                      Checked="SaveToFileCheck_Changed" Unchecked="SaveToFileCheck_Changed"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" x:Name="SaveDirPanel" Visibility="Collapsed">
                                <TextBox x:Name="SaveDirBox" IsReadOnly="True" FontSize="11" Padding="7,4" Width="280"
                                         Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                                <Button Content="Browse" FontSize="11" Padding="8,4" Margin="5,0,0,0" Click="BrowseButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="SaveHistoryCheck" Content="Save capture history" FontSize="13"
                                      Checked="SaveHistoryCheck_Changed" Unchecked="SaveHistoryCheck_Changed"/>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Auto-clear" FontSize="12" Opacity="0.6"/>
                                </StackPanel>
                                <ComboBox x:Name="HistoryRetentionCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="120"
                                          SelectionChanged="HistoryRetentionCombo_SelectionChanged">
                                    <ComboBoxItem Content="Never"/>
                                    <ComboBoxItem Content="1 day"/>
                                    <ComboBoxItem Content="7 days"/>
                                    <ComboBoxItem Content="30 days"/>
                                    <ComboBoxItem Content="3 months"/>
                                </ComboBox>
                            </Grid>

                            <CheckBox x:Name="CompressHistoryCheck" Content="Compress history (JPEG)" FontSize="12" Margin="0,8,0,0"
                                      Checked="CompressHistoryCheck_Changed" Unchecked="CompressHistoryCheck_Changed"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="TOOLBAR" Style="{StaticResource SectionLabel}" Margin="4,16,0,6"/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Choose which tools appear in the capture toolbar" FontSize="12" Opacity="0.35" Margin="0,0,0,8"/>
                            <CheckBox x:Name="ShowToolNumberBadgesCheck" Content="Show numbered tool badges on hover" FontSize="12"
                                      Margin="0,0,0,8" Checked="ShowToolNumberBadgesCheck_Changed" Unchecked="ShowToolNumberBadgesCheck_Changed"/>
                            <WrapPanel x:Name="ToolTogglePanel" Orientation="Horizontal"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="GENERAL" Style="{StaticResource SectionLabel}" Margin="4,16,0,6"/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="MuteSoundsCheck" Content="Mute capture sounds" FontSize="13"
                                      Checked="MuteSoundsCheck_Changed" Unchecked="MuteSoundsCheck_Changed"/>

                            <Border Height="1" Background="#0AFFFFFF" Margin="0,10,0,10"/>

                            <CheckBox x:Name="CrosshairGuidesCheck" Content="Show crosshair guides" FontSize="13"
                                      Checked="CrosshairGuidesCheck_Changed" Unchecked="CrosshairGuidesCheck_Changed"/>

                            <Border Height="1" Background="#0AFFFFFF" Margin="0,10,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Toast position" FontSize="13"/>
                                    <TextBlock Text="Where notifications appear" FontSize="11" Opacity="0.25"/>
                                </StackPanel>
                                <ComboBox x:Name="ToastPositionCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="125"
                                          SelectionChanged="ToastPositionCombo_SelectionChanged">
                                    <ComboBoxItem Content="Right"/>
                                    <ComboBoxItem Content="Left"/>
                                    <ComboBoxItem Content="Top Left"/>
                                    <ComboBoxItem Content="Top Right"/>
                                </ComboBox>
                            </Grid>

                            <Border Height="1" Background="#0AFFFFFF" Margin="0,10,0,10"/>

                            <CheckBox x:Name="StartWithWindowsCheck" Content="Launch on startup" FontSize="13"
                                      Checked="StartWithWindowsCheck_Changed" Unchecked="StartWithWindowsCheck_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- About -->
                    <TextBlock FontSize="10.5" Opacity="0.15" HorizontalAlignment="Center" Margin="0,18,0,2">
                        <Run Text="Yoink v0.1.0"/>
                    </TextBlock>
                    <TextBlock HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Hyperlink NavigateUri="https://github.com/jasperdevs/yoink" RequestNavigate="Hyperlink_Navigate"
                                   Foreground="#1962F4" FontSize="10.5">GitHub</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>

            <!-- History (merged: Screenshots + Text sub-tabs) -->
            <Grid x:Name="HistoryPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sub-tabs -->
                <Border Grid.Row="0" Padding="14,4,14,2">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ImagesSubTab" Content="Images" GroupName="HistSub"
                                         IsChecked="True" Click="HistorySubTabChanged" Style="{StaticResource SubTab}"/>
                            <RadioButton x:Name="TextSubTab" Content="Text" GroupName="HistSub"
                                         Click="HistorySubTabChanged" Margin="2,0,0,0" Style="{StaticResource SubTab}"/>
                            <RadioButton x:Name="GifsSubTab" Content="GIFs" GroupName="HistSub"
                                         Click="HistorySubTabChanged" Margin="2,0,0,0" Style="{StaticResource SubTab}"/>
                            <RadioButton x:Name="ColorsSubTab" Content="Colors" GroupName="HistSub"
                                         Click="HistorySubTabChanged" Margin="2,0,0,0" Style="{StaticResource SubTab}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="SelectBtn" Content="Select" FontSize="10" Padding="8,3"
                                     Margin="0,0,3,0" Click="ToggleSelectMode"/>
                            <Button x:Name="DeleteAllBtn" Content="Delete All" FontSize="10" Padding="8,3"
                                    Margin="0,0,3,0" Click="DeleteAllClick"/>
                            <Button x:Name="DeleteSelectedBtn" Content="Delete" FontSize="10"
                                     Padding="8,3" Visibility="Collapsed" Click="DeleteSelectedClick"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Images history -->
                <ScrollViewer x:Name="ImagesPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,2,10,4"
                              ScrollChanged="HistoryPanel_ScrollChanged">
                    <StackPanel x:Name="HistoryStack"/>
                </ScrollViewer>

                <!-- GIF history -->
                <ScrollViewer x:Name="GifsPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,2,10,4"
                              ScrollChanged="GifPanel_ScrollChanged"
                              Visibility="Collapsed">
                    <StackPanel x:Name="GifStack"/>
                </ScrollViewer>

                <!-- Text history -->
                <ScrollViewer x:Name="TextPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="14,2,14,14" Visibility="Collapsed">
                    <StackPanel x:Name="OcrStack"/>
                </ScrollViewer>

                <!-- Color history -->
                <ScrollViewer x:Name="ColorsPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="14,2,14,14" Visibility="Collapsed">
                    <WrapPanel x:Name="ColorStack"/>
                </ScrollViewer>

                <!-- Empty states -->
                <StackPanel x:Name="HistoryEmptyText" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="&#x1F4F7;" FontSize="32" HorizontalAlignment="Center" Opacity="0.15"/>
                    <TextBlock x:Name="HistoryEmptyLabel" Text="No captures yet" FontSize="13" Opacity="0.2"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Bottom bar -->
                <Border Grid.Row="2" Padding="14,4,14,8">
                    <TextBlock x:Name="HistoryCountText" FontSize="11" Opacity="0.25" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Uploads -->
            <ScrollViewer x:Name="UploadsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="18,4,18,18">
                <StackPanel>
                    <TextBlock Text="DESTINATION" Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Upload service" FontSize="13"/>
                                    <TextBlock Text="Where captures are uploaded" FontSize="11" Opacity="0.25"/>
                                </StackPanel>
                                <ComboBox x:Name="UploadDestCombo" Grid.Column="1" FontSize="12" Padding="8,5" MinWidth="145"
                                          SelectionChanged="UploadDestCombo_Changed">
                                    <ComboBoxItem Content="None"/>
                                    <ComboBoxItem Content="Imgur"/>
                                    <ComboBoxItem Content="ImgBB"/>
                                    <ComboBoxItem Content="Catbox"/>
                                    <ComboBoxItem Content="Litterbox (temp)"/>
                                    <ComboBoxItem Content="Gyazo"/>
                                    <ComboBoxItem Content="file.io"/>
                                    <ComboBoxItem Content="Uguu (temp)"/>
                                    <ComboBoxItem Content="transfer.sh"/>
                                    <ComboBoxItem Content="Dropbox"/>
                                    <ComboBoxItem Content="Google Drive"/>
                                    <ComboBoxItem Content="OneDrive"/>
                                    <ComboBoxItem Content="Azure Blob"/>
                                    <ComboBoxItem Content="GitHub"/>
                                    <ComboBoxItem Content="Immich"/>
                                    <ComboBoxItem Content="Streamable"/>
                                    <ComboBoxItem Content="FTP"/>
                                    <ComboBoxItem Content="SFTP"/>
                                    <ComboBoxItem Content="WebDAV"/>
                                    <ComboBoxItem Content="S3 / R2 / B2"/>
                                    <ComboBoxItem Content="Custom HTTP"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Imgur settings -->
                    <StackPanel x:Name="ImgurSettings" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="4,16,0,6">
                            <Border Width="24" Height="24" CornerRadius="7" Background="#16FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Image Source="pack://application:,,,/Assets/imgur_sq.png" Width="16" Height="16" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Text="IMGUR" Style="{StaticResource SectionLabel}" Margin="0"/>
                        </StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border CornerRadius="3" Background="#15FFFFFF" Padding="5,2" Margin="0,0,4,0">
                                        <TextBlock Text="PNG" FontSize="9" Opacity="0.6"/>
                                    </Border>
                                    <Border CornerRadius="3" Background="#15FFFFFF" Padding="5,2" Margin="0,0,4,0">
                                        <TextBlock Text="JPG" FontSize="9" Opacity="0.6"/>
                                    </Border>
                                    <Border CornerRadius="3" Background="#15FFFFFF" Padding="5,2" Margin="0,0,4,0">
                                        <TextBlock Text="GIF" FontSize="9" Opacity="0.6"/>
                                    </Border>
                                    <TextBlock Text="  20MB images · 200MB GIF · Free" FontSize="10" Opacity="0.3" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="1,250 uploads/day anonymous · 12,500/day with account" FontSize="10" Opacity="0.25" Margin="0,0,0,8"/>
                                <TextBlock Text="Anonymous uploads work without any configuration. Add your own credentials for account uploads." FontSize="11" Opacity="0.35" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                <TextBlock Text="Client ID" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBlock Text="Optional — has built-in default for anonymous uploads" FontSize="11" Opacity="0.25" Margin="0,0,0,4"/>
                                <TextBox x:Name="ImgurClientIdBox" FontSize="11" Padding="7,4"
                                         Background="#1A1A1A" Foreground="#99FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"
                                         TextChanged="ImgurClientIdBox_Changed"/>

