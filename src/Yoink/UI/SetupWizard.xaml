<Window x:Class="Yoink.UI.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Width="480" Height="520" Topmost="True"
        SourceInitialized="OnSourceInit">

    <Window.Resources>
        <Style x:Key="WizBtn" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Margin="16" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.5" Color="Black"/>
        </Border.Effect>
    <Border CornerRadius="12" ClipToBounds="True" Background="#202020"
            BorderBrush="#18FFFFFF" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pages -->
        <Grid x:Name="Page1" Grid.Row="0" Margin="32,28,32,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Welcome to Yoink" FontSize="24" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="A fast screenshot tool for Windows." FontSize="13"
                           Foreground="White" Opacity="0.4" HorizontalAlignment="Center" Margin="0,6,0,28"/>

                <TextBlock Text="Hotkeys" FontSize="14" FontWeight="SemiBold" Foreground="White" Opacity="0.7" Margin="0,0,0,10"/>

                <Border Background="#282828" CornerRadius="6" Padding="14,10" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Screenshot" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                        <TextBox x:Name="SetupHotkeyBox" Grid.Column="1" IsReadOnly="True"
                                 FontSize="12" Padding="10,5" MinWidth="120" TextAlignment="Center"
                                 PreviewKeyDown="SetupHotkey_PreviewKeyDown"/>
                    </Grid>
                </Border>

                <Border Background="#282828" CornerRadius="6" Padding="14,10" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="OCR Text Capture" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                        <TextBox x:Name="SetupOcrHotkeyBox" Grid.Column="1" IsReadOnly="True"
                                 FontSize="12" Padding="10,5" MinWidth="120" TextAlignment="Center"
                                 PreviewKeyDown="SetupOcrHotkey_PreviewKeyDown"/>
                    </Grid>
                </Border>

                <Border Background="#282828" CornerRadius="6" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Color Picker" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                        <TextBox x:Name="SetupPickerHotkeyBox" Grid.Column="1" IsReadOnly="True"
                                 FontSize="12" Padding="10,5" MinWidth="120" TextAlignment="Center"
                                 PreviewKeyDown="SetupPickerHotkey_PreviewKeyDown"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>

        <Grid x:Name="Page2" Grid.Row="0" Margin="32,28,32,0" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Toolbar" FontSize="24" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Choose which tools appear in the capture toolbar." FontSize="13"
                           Foreground="White" Opacity="0.4" HorizontalAlignment="Center" Margin="0,6,0,24"/>
                <WrapPanel x:Name="SetupToolPanel" Orientation="Horizontal" HorizontalAlignment="Center"/>

                <TextBlock Text="You can change these later in settings." FontSize="11"
                           Foreground="White" Opacity="0.2" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Bottom bar -->
        <Border Grid.Row="1" Padding="24,12,24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="PageIndicator" Text="1 / 2" FontSize="12" Foreground="White"
                           Opacity="0.25" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BackBtn" Content="Back" Style="{StaticResource WizBtn}"
                            Click="Back_Click" Visibility="Collapsed" Margin="0,0,8,0"/>
                    <Button x:Name="NextBtn" Content="Next" Style="{StaticResource WizBtn}"
                            Click="Next_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </Border>
    </Border>
</Window>
