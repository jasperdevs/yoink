<Window x:Class="Yoink.UI.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Width="580" Height="680" Topmost="True"
        SourceInitialized="OnSourceInit"
        MouseLeftButtonDown="Window_MouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="WizBg" Color="#1F1F1F"/>
        <SolidColorBrush x:Key="WizCardBg" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="WizFg" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="WizFgMuted" Color="#99F0F0F0"/>
        <SolidColorBrush x:Key="WizBorder" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="WizInputBg" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="WizBtnPrimaryBg" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="WizBtnPrimaryFg" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="WizBtnSecondaryBg" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="WizBtnSecondaryFg" Color="#CCF0F0F0"/>
        <SolidColorBrush x:Key="WizBtnPrimaryBorder" Color="#20000000"/>
        <Color x:Key="WizShadowColor">#80000000</Color>

        <Style x:Key="WizBtn" TargetType="Button" BasedOn="{StaticResource ChromeButtonBase}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style x:Key="WizBtnPrimary" TargetType="Button" BasedOn="{StaticResource WizBtn}">
            <Setter Property="Background" Value="{DynamicResource WizBtnPrimaryBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource WizBtnPrimaryFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WizBtnPrimaryBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="WizBtnSecondary" TargetType="Button" BasedOn="{StaticResource WizBtn}">
            <Setter Property="Background" Value="{DynamicResource WizBtnSecondaryBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource WizBtnSecondaryFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WizBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <ControlTemplate x:Key="WizHotkeyBoxTemplate" TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                <ScrollViewer x:Name="PART_ContentHost"/>
            </Border>
        </ControlTemplate>

        <Style x:Key="WizRow" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource WizCardBg}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WizBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Border Margin="16" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.5" Color="{DynamicResource WizShadowColor}"/>
        </Border.Effect>
    <Border x:Name="WizardBorder" CornerRadius="12" ClipToBounds="True"
            Background="{DynamicResource WizBg}" BorderBrush="{DynamicResource WizBorder}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page 1: Welcome + Capture Hotkeys -->
        <Grid x:Name="Page1" Grid.Row="0" Margin="36,28,36,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                <StackPanel>
                    <Image Source="pack://application:,,,/yoink.ico" Width="44" Height="44"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Welcome to Yoink" FontSize="24" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable Display"
                               Foreground="{DynamicResource WizFg}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Set up your capture hotkeys" FontSize="13"
                               FontFamily="Segoe UI Variable Text"
                               Foreground="{DynamicResource WizFgMuted}" HorizontalAlignment="Center" Margin="0,4,0,20"/>

                    <!-- Capture tool hotkeys — populated by code-behind -->
                    <StackPanel x:Name="HotkeyPanel"/>

                    <TextBlock Text="All hotkeys can be changed later in Settings"
                               FontSize="11" FontFamily="Segoe UI Variable Text"
                               Foreground="{DynamicResource WizFgMuted}" HorizontalAlignment="Center"
                               Margin="0,12,0,0" Opacity="0.5"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Page 2: Preferences -->
        <Grid x:Name="Page2" Grid.Row="0" Margin="36,28,36,0" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Preferences" FontSize="24" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display"
                           Foreground="{DynamicResource WizFg}" HorizontalAlignment="Center"/>
                <TextBlock Text="Almost there!" FontSize="13"
                           FontFamily="Segoe UI Variable Text"
                           Foreground="{DynamicResource WizFgMuted}" HorizontalAlignment="Center" Margin="0,4,0,20"/>

                <Border Style="{StaticResource WizRow}">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="After capture" FontSize="13" Foreground="{DynamicResource WizFg}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="WizAfterCombo" Grid.Column="1" MinWidth="160" Padding="8,5" FontSize="12">
                            <ComboBoxItem Content="Copy to clipboard"/><ComboBoxItem Content="Show preview"/>
                        </ComboBox>
                    </Grid>
                </Border>
                <Border Style="{StaticResource WizRow}">
                    <CheckBox x:Name="WizCrosshairCheck" Content="Show crosshair guides during capture" FontSize="13"
                              Foreground="{DynamicResource WizFg}" Cursor="Hand"/>
                </Border>
                <Border Style="{StaticResource WizRow}">
                    <CheckBox x:Name="WizCaptureMagnifierCheck" Content="Show pixel magnifier near cursor during capture" FontSize="13"
                              Foreground="{DynamicResource WizFg}" Cursor="Hand"/>
                </Border>
                <Border Style="{StaticResource WizRow}">
                    <CheckBox x:Name="WizMuteCheck" Content="Mute capture sounds" FontSize="13"
                              Foreground="{DynamicResource WizFg}" Cursor="Hand"/>
                </Border>
                <Border Style="{StaticResource WizRow}">
                    <CheckBox x:Name="WizAutoUpdateCheck" Content="Check for updates automatically" FontSize="13"
                              Foreground="{DynamicResource WizFg}" Cursor="Hand" IsChecked="True"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Page 3: You're all set -->
        <Grid x:Name="Page3" Grid.Row="0" Margin="40,32,40,0" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="pack://application:,,,/yoink.ico" Width="56" Height="56"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="You're all set!" FontSize="26" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display"
                           Foreground="{DynamicResource WizFg}" HorizontalAlignment="Center"/>
                <TextBlock FontSize="13" FontFamily="Segoe UI Variable Text" TextAlignment="Center"
                           Foreground="{DynamicResource WizFgMuted}" HorizontalAlignment="Center"
                           Margin="0,10,0,0" LineHeight="22">
                    Yoink runs in your system tray.
                    <LineBreak/>
                    Right-click the tray icon anytime to capture,
                    <LineBreak/>
                    record, or open settings.
                </TextBlock>
                <TextBlock FontSize="12" FontFamily="Segoe UI Variable Text" TextAlignment="Center"
                           Foreground="{DynamicResource WizFgMuted}" HorizontalAlignment="Center"
                           Margin="0,24,0,0" Opacity="0.5">
                    Customize all tools, hotkeys, uploads,
                    <LineBreak/>
                    and more in Settings.
                </TextBlock>

                <Button Content="Open Settings" Style="{StaticResource WizBtnSecondary}"
                        HorizontalAlignment="Center" Margin="0,20,0,0"
                        Click="OpenSettings_Click"/>
            </StackPanel>
        </Grid>

        <!-- Bottom bar -->
        <Border Grid.Row="1" Padding="28,12,28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="7" Height="7" CornerRadius="4" x:Name="Dot1"
                            Background="{DynamicResource WizFg}" Opacity="0.7" Margin="0,0,5,0"/>
                    <Border Width="7" Height="7" CornerRadius="4" x:Name="Dot2"
                            Background="{DynamicResource WizFg}" Opacity="0.2" Margin="0,0,5,0"/>
                    <Border Width="7" Height="7" CornerRadius="4" x:Name="Dot3"
                            Background="{DynamicResource WizFg}" Opacity="0.2"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BackBtn" Content="Back" Style="{StaticResource WizBtnSecondary}"
                            Click="Back_Click" Visibility="Collapsed" Margin="0,0,8,0"/>
                    <Button x:Name="NextBtn" Content="Next" Style="{StaticResource WizBtnPrimary}"
                            Click="Next_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </Border>
    </Border>
</Window>
