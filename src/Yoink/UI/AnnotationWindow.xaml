<Window x:Class="Yoink.UI.AnnotationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yoink - Edit"
        WindowStartupLocation="CenterScreen"
        ThemeMode="System"
        MinWidth="500" MinHeight="400">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="-1" CornerRadius="8"
                      UseAeroCaptionButtons="True"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar in title bar -->
        <Border Grid.Row="0" Padding="12,6,12,6">
            <StackPanel Orientation="Horizontal">
                <!-- Tools -->
                <RadioButton x:Name="ArrowBtn" Content="Arrow" GroupName="Tool"
                             IsChecked="True" Click="ToolChanged"
                             Padding="8,4" Margin="0,0,2,0" Tag="Arrow"
                             WindowChrome.IsHitTestVisibleInChrome="True"/>
                <RadioButton x:Name="TextBtn" Content="Text" GroupName="Tool"
                             Click="ToolChanged"
                             Padding="8,4" Margin="0,0,2,0" Tag="Text"
                             WindowChrome.IsHitTestVisibleInChrome="True"/>
                <RadioButton x:Name="HighlighterBtn" Content="Highlight" GroupName="Tool"
                             Click="ToolChanged"
                             Padding="8,4" Margin="0,0,2,0" Tag="Highlighter"
                             WindowChrome.IsHitTestVisibleInChrome="True"/>
                <RadioButton x:Name="RectBtn" Content="Rect" GroupName="Tool"
                             Click="ToolChanged"
                             Padding="8,4" Margin="0,0,2,0" Tag="Rectangle"
                             WindowChrome.IsHitTestVisibleInChrome="True"/>
                <RadioButton x:Name="BlurBtn" Content="Blur" GroupName="Tool"
                             Click="ToolChanged"
                             Padding="8,4" Margin="0,0,12,0" Tag="Blur"
                             WindowChrome.IsHitTestVisibleInChrome="True"/>

                <!-- Colors -->
                <Border Width="20" Height="20" CornerRadius="10" Background="#FF4444"
                        Margin="0,0,3,0" MouseLeftButtonDown="ColorPicked" Tag="Red" Cursor="Hand"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Border Width="20" Height="20" CornerRadius="10" Background="#FF8800"
                        Margin="0,0,3,0" MouseLeftButtonDown="ColorPicked" Tag="Orange" Cursor="Hand"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Border Width="20" Height="20" CornerRadius="10" Background="#FFCC00"
                        Margin="0,0,3,0" MouseLeftButtonDown="ColorPicked" Tag="Yellow" Cursor="Hand"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Border Width="20" Height="20" CornerRadius="10" Background="#44BB44"
                        Margin="0,0,3,0" MouseLeftButtonDown="ColorPicked" Tag="Green" Cursor="Hand"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Border Width="20" Height="20" CornerRadius="10" Background="#4488FF"
                        Margin="0,0,3,0" MouseLeftButtonDown="ColorPicked" Tag="Blue" Cursor="Hand"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Border Width="20" Height="20" CornerRadius="10" Background="White"
                        Margin="0,0,12,0" MouseLeftButtonDown="ColorPicked" Tag="White" Cursor="Hand"
                        BorderBrush="#40FFFFFF" BorderThickness="1"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>

                <!-- Actions -->
                <Button Content="Undo" Click="UndoClick" Padding="8,4" Margin="0,0,2,0"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button Content="Redo" Click="RedoClick" Padding="8,4" Margin="0,0,12,0"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>

                <Button Content="Copy" Click="CopyClick" Padding="8,4" Margin="0,0,2,0" FontWeight="SemiBold"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button Content="Save" Click="SaveClick" Padding="8,4"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
            </StackPanel>
        </Border>

        <!-- Canvas -->
        <Border Grid.Row="1" ClipToBounds="True">
            <Canvas x:Name="DrawCanvas"
                    MouseLeftButtonDown="Canvas_MouseDown"
                    MouseMove="Canvas_MouseMove"
                    MouseLeftButtonUp="Canvas_MouseUp"
                    ClipToBounds="True"/>
        </Border>
    </Grid>
</Window>
