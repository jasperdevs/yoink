<Window x:Class="Yoink.UI.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Focusable="False"
        ShowActivated="False">

    <Border x:Name="Root" CornerRadius="8" Padding="12,8,12,8" BorderThickness="1"
            MaxWidth="320" MinWidth="180">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideX" X="0"/>
        </Border.RenderTransform>

        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="12" FontWeight="SemiBold"/>
            <TextBlock x:Name="BodyText" FontSize="11" Opacity="0.55" TextWrapping="Wrap"
                       MaxWidth="280" Margin="0,2,0,0"/>
        </StackPanel>
    </Border>
</Window>
