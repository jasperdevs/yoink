<Window x:Class="Yoink.UI.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Focusable="False"
        ShowActivated="False">

    <Border x:Name="Root" CornerRadius="10" ClipToBounds="True"
            MaxWidth="340" MinWidth="180">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.35" Color="Black"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideX" X="0"/>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Image preview area (hidden for text-only toasts) -->
            <Grid x:Name="ImageArea" Grid.Row="0" Visibility="Collapsed" MaxHeight="160">
                <Border CornerRadius="10,10,0,0" ClipToBounds="True">
                    <Image x:Name="PreviewImage" Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- Overlay buttons (shown on hover) -->
                <Border x:Name="CloseBtn" Width="26" Height="26" CornerRadius="6"
                        Background="#90000000" Cursor="Hand"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,5,5,0" Opacity="0">
                    <Canvas Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Line X1="0" Y1="0" X2="8" Y2="8" Stroke="White" StrokeThickness="1.3"/>
                        <Line X1="8" Y1="0" X2="0" Y2="8" Stroke="White" StrokeThickness="1.3"/>
                    </Canvas>
                </Border>
                <Border x:Name="PinBtn" Width="26" Height="26" CornerRadius="6"
                        Background="#90000000" Cursor="Hand"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="5,5,0,0" Opacity="0">
                    <Path x:Name="PinIcon"
                          Data="M16,12V4h1V2H7V4h1v8l-2,2v2h5.2v6h1.6v-6H18v-2Z"
                          Fill="White" Stretch="Uniform" Width="10" Height="10" Opacity="0.9"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border x:Name="SaveBtn" Width="26" Height="26" CornerRadius="6"
                        Background="#90000000" Cursor="Hand"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,5,5" Opacity="0">
                    <Path Data="M19,12v7H5v-7H3v7c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2v-7H19z M13,12.67l2.59-2.58L17,11.5l-5,5l-5-5l1.41-1.41L11,12.67V3h2V12.67z"
                          Fill="White" Stretch="Uniform" Width="10" Height="10" Opacity="0.9"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Text content -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="14,10,14,8">
                <Border x:Name="ColorSwatch" Width="28" Height="28" CornerRadius="6"
                        Margin="0,0,12,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="12.5" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable Text"/>
                    <TextBlock x:Name="BodyText" FontSize="11" Opacity="0.5" TextWrapping="Wrap"
                               FontFamily="Segoe UI Variable Text"
                               MaxWidth="280" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Progress bar -->
            <Border x:Name="ProgressBar" Grid.Row="2" Height="3.5"
                    Background="#70FFFFFF" CornerRadius="0,0,10,10"
                    HorizontalAlignment="Stretch"
                    RenderTransformOrigin="0,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="ProgressScale" ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
            </Border>
        </Grid>
    </Border>
</Window>
