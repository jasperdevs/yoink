<Window x:Class="Yoink.UI.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True"
        Focusable="False"
        ShowActivated="False">

    <Border x:Name="OuterShell"
            CornerRadius="12"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            SnapsToDevicePixels="True">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="DragScale" ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="SlideTransform" X="0" Y="0"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Border x:Name="Root" CornerRadius="10" ClipToBounds="True"
                MaxWidth="360" MinWidth="196"
                SnapsToDevicePixels="True">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3"/>
            </Grid.RowDefinitions>

            <Grid x:Name="ContentGrid" Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Image preview area (hidden for text-only toasts) -->
                <Grid x:Name="ImageArea" Grid.Row="0" Visibility="Collapsed" MaxHeight="176" HorizontalAlignment="Center">
                    <Border x:Name="ImageFrame" CornerRadius="10,10,0,0" ClipToBounds="True">
                        <Image x:Name="PreviewImage" Stretch="Uniform"
                               UseLayoutRounding="True"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <!-- Overlay buttons (shown on hover) -->
                    <Border x:Name="CloseBtn" Width="32" Height="32" CornerRadius="8"
                            Background="#E0202024" BorderBrush="#30FFFFFF" BorderThickness="0.8"
                            ToolTipService.IsEnabled="False"
                            Cursor="Hand"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,8,8,0" Opacity="0" Visibility="Collapsed">
                        <Image x:Name="CloseIcon" Width="14" Height="14" Stretch="Uniform" Opacity="0.9"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="PinBtn" Width="32" Height="32" CornerRadius="8"
                            Background="#E0202024" BorderBrush="#30FFFFFF" BorderThickness="0.8"
                            ToolTipService.IsEnabled="False"
                            Cursor="Hand"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="8,8,0,0" Opacity="0" Visibility="Collapsed">
                        <Image x:Name="PinIcon" Width="14" Height="14" Stretch="Uniform" Opacity="0.9"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="SaveBtn" Width="32" Height="32" CornerRadius="8"
                            Background="#E0202024" BorderBrush="#30FFFFFF" BorderThickness="0.8"
                            ToolTipService.IsEnabled="False"
                            Cursor="Hand"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,8,8" Opacity="0" Visibility="Collapsed">
                        <Image x:Name="SaveIcon" Width="14" Height="14" Stretch="Uniform" Opacity="0.9"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="DeleteBtn" Width="32" Height="32" CornerRadius="8"
                            Background="#E0202024" BorderBrush="#30FFFFFF" BorderThickness="0.8"
                            ToolTipService.IsEnabled="False"
                            Cursor="Hand"
                            HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="8,0,0,8" Opacity="0" Visibility="Collapsed">
                        <Image x:Name="DeleteIcon" Width="14" Height="14" Stretch="Uniform" Opacity="0.9"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Text content -->
                <StackPanel x:Name="TextContentPanel" Grid.Row="1" Orientation="Horizontal" Margin="14,11,14,11">
                    <Border x:Name="ColorSwatch" Width="28" Height="28" CornerRadius="8"
                            Margin="0,0,12,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                    <Border x:Name="InlinePreviewHost" Width="44" Height="44" CornerRadius="8"
                            Margin="0,0,12,0" Visibility="Collapsed" VerticalAlignment="Center"
                            Background="#12FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1">
                        <Image x:Name="InlinePreviewImage" Stretch="Uniform" Margin="4"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText" FontSize="12.75" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable Text"/>
                        <TextBlock x:Name="BodyText" FontSize="11.5" Opacity="0.72" TextWrapping="Wrap"
                                   FontFamily="Segoe UI Variable Text"
                                   MaxWidth="292" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" ClipToBounds="True">
                <Border x:Name="ProgressTrack"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"/>
                <Border x:Name="ProgressBar"
                        Background="#8CFFFFFF"
                        HorizontalAlignment="Stretch"
                        RenderTransformOrigin="0,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ProgressScale" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                </Border>
            </Grid>

            <Border x:Name="ShellStroke"
                    Grid.RowSpan="2"
                    Margin="0"
                    CornerRadius="10"
                    Background="Transparent"
                    BorderThickness="1"
                    SnapsToDevicePixels="True"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"/>
            </Grid>
        </Border>
    </Border>
</Window>
