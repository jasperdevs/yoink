<Window x:Class="Yoink.UI.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Focusable="False"
        ShowActivated="False">

    <Grid>
        <Border x:Name="Root" CornerRadius="12" Padding="12,8,12,8"
                MaxWidth="320" MinWidth="180">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.4" Color="Black"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="SlideX" X="0"/>
            </Border.RenderTransform>

            <StackPanel Orientation="Horizontal">
                <Border x:Name="ColorSwatch" Width="28" Height="28" CornerRadius="5"
                        Margin="0,0,10,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="BodyText" FontSize="11" Opacity="0.55" TextWrapping="Wrap"
                               MaxWidth="280" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Image x:Name="StickerImage" Visibility="Collapsed" MaxWidth="220" MaxHeight="220" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.28" Color="Black"/>
            </Image.Effect>
        </Image>
    </Grid>
</Window>
