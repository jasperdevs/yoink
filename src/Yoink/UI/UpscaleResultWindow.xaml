<Window x:Class="Yoink.UI.UpscaleResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upscale"
        Height="720" Width="1080"
        MinHeight="560" MinWidth="760"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        Icon="pack://application:,,,/yoink.ico"
        PreviewKeyDown="Window_PreviewKeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" CornerRadius="12"
                      ResizeBorderThickness="8" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#FFF0F0F0"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#FF9A9A9A"/>
        <SolidColorBrush x:Key="ThemeMutedBrush" Color="#FF686868"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ThemeWindowBorderBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="UpscaleShimmerBrush" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="LoadingTextBrush" Color="#FFFFFFFF"/>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="12" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="16,8,0,0" MouseDown="TitleBar_MouseDown" Background="Transparent">
                <Grid>
                    <TextBlock Text="Upscale" FontSize="12.5" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable Display"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.85"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-8,0,0">
                        <Border Width="40" Height="34" CornerRadius="0" Cursor="Hand" Background="Transparent"
                                MouseDown="MinimizeBtn_Click" MouseEnter="TitleBtn_Enter" MouseLeave="TitleBtn_Leave">
                            <Image x:Name="MinimizeTitleIcon" Width="14" Height="14" Stretch="Uniform" Opacity="0.8"/>
                        </Border>
                        <Border x:Name="CloseTitleBtn" Width="40" Height="34" CornerRadius="0,11,0,0" Cursor="Hand" Background="Transparent"
                                MouseDown="CloseBtn_Click" MouseEnter="TitleBtn_Enter" MouseLeave="TitleBtn_Leave">
                            <Image x:Name="CloseTitleIcon" Width="14" Height="14" Stretch="Uniform" Opacity="0.8"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="14,0,14,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="16"
                        CornerRadius="10"
                        Background="{DynamicResource ThemeCardBrush}"
                        BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Scale" FontSize="11" Opacity="0.5" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <Slider x:Name="ScaleSlider"
                                    Margin="0,10,0,0"
                                    Minimum="2"
                                    Maximum="4"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="ScaleSlider_ValueChanged"/>
                            <TextBlock x:Name="ScaleValueText"
                                       Margin="0,8,0,0"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,18,0,0">
                            <TextBlock Text="Model" FontSize="11" Opacity="0.5" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <ComboBox x:Name="ModelCombo"
                                      Margin="0,8,0,0"
                                      FontSize="12"
                                      Padding="8,5"
                                      SelectionChanged="ModelCombo_SelectionChanged"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   x:Name="StatusText"
                                   Margin="0,18,0,0"
                                   FontSize="11"
                                   Opacity="0.62"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   Text="Pick a scale and model, then run a before-and-after preview."/>

                        <StackPanel Grid.Row="4">
                            <Button x:Name="UpscaleBtn"
                                    FontSize="12"
                                    Padding="18,10"
                                    Click="UpscaleBtn_Click"
                                    Background="{DynamicResource ThemeInputBackgroundBrush}"
                                    Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                    BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                    BorderThickness="1"
                                    Content="Upscale"/>
                            <Grid Margin="0,8,0,0">
                                <Button x:Name="UseResultBtn"
                                        FontSize="12"
                                        Padding="18,10"
                                        Click="UseResultBtn_Click"
                                        Background="{DynamicResource ThemeInputBackgroundBrush}"
                                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                        BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                        BorderThickness="1"
                                        IsEnabled="False">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Image x:Name="UseResultIcon"
                                               Width="15"
                                               Height="15"
                                               Margin="0,0,8,0"/>
                                        <TextBlock Text="Use Result" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Padding="14"
                        CornerRadius="10"
                        Background="{DynamicResource ThemeCardBrush}"
                        BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                        BorderThickness="1">
                    <Border x:Name="CompareSurface"
                            CornerRadius="10"
                            Background="{DynamicResource ThemeInputBackgroundBrush}"
                            BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                            BorderThickness="1"
                            SizeChanged="CompareSurface_SizeChanged"
                            MouseLeftButtonDown="CompareSurface_MouseLeftButtonDown"
                            MouseLeftButtonUp="CompareSurface_MouseLeftButtonUp"
                            MouseMove="CompareSurface_MouseMove">
                        <Grid ClipToBounds="True">
                            <Grid x:Name="CompareImageLayer">
                                <Grid.Effect>
                                    <BlurEffect x:Name="CompareImageBlur" Radius="0"/>
                                </Grid.Effect>
                                <Image x:Name="CompareBeforeImage"
                                       Stretch="Fill"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>

                                <Image x:Name="CompareAfterImage"
                                       Stretch="Fill"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Visibility="Collapsed"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Clip>
                                        <RectangleGeometry x:Name="CompareAfterClip"/>
                                    </Image.Clip>
                                </Image>

                                <Border x:Name="CompareDivider"
                                        Width="2"
                                        Background="#F4FFFFFF"
                                        HorizontalAlignment="Left"
                                        Visibility="Collapsed"/>

                                <Grid x:Name="CompareHandle"
                                      Width="44"
                                      Height="44"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Margin="-22,0,0,0"
                                      Visibility="Collapsed"
                                      IsHitTestVisible="False">
                                    <Ellipse Fill="#F8FFFFFF"/>
                                    <Ellipse Margin="1.5"
                                             Fill="#10FFFFFF"
                                             Stroke="#33000000"
                                             StrokeThickness="1"/>
                                    <Path Stroke="#AA000000"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M17,22 L12,17 M17,22 L12,27 M27,22 L32,17 M27,22 L32,27"/>
                                </Grid>
                            </Grid>

                            <TextBlock x:Name="BeforeCornerLabel"
                                       Text="Before"
                                       Margin="14,12,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="White">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.45"/>
                                </TextBlock.Effect>
                            </TextBlock>

                            <TextBlock x:Name="AfterCornerLabel"
                                       Text="After"
                                       Margin="0,12,14,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="White">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.45"/>
                                </TextBlock.Effect>
                            </TextBlock>

                            <Grid x:Name="AfterLoadingOverlay"
                                  Background="#66111113"
                                  Visibility="Collapsed">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="AfterLoadingTitle"
                                               Margin="0,0,0,0"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource LoadingTextBrush}"
                                               Text="Generating"/>
                                    <TextBlock x:Name="AfterLoadingSubtitle"
                                               Margin="0,4,0,0"
                                               HorizontalAlignment="Center"
                                               FontSize="10"
                                               Foreground="{StaticResource LoadingTextBrush}"
                                               Opacity="0.5"
                                               Text="Local model"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
