                                <Button Content="Uninstall OddSnap" Style="{StaticResource DangerButton}"
                                        Click="UninstallButton_Click" Margin="0,0,10,8"/>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="VersionText" FontSize="10.5" Opacity="0.28" HorizontalAlignment="Center" Margin="0,18,0,4"/>

                    <TextBlock Text="Links" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"/>
                    <Border Style="{StaticResource Card}">
