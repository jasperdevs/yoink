                                <Run Text=" — GitHub repository" FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </TextBlock>
                            <TextBlock Margin="0,0,0,7">
                                <Hyperlink NavigateUri="https://github.com/jasperdevs/odd-snap/releases/latest" RequestNavigate="Hyperlink_Navigate"
                                           Style="{StaticResource AboutActionLink}" FontSize="12">Releases</Hyperlink>
                                <Run Text=" — Download the latest version" FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </TextBlock>
                            <TextBlock Margin="0,0,0,7">
                                <Hyperlink NavigateUri="https://github.com/jasperdevs/odd-snap/issues" RequestNavigate="Hyperlink_Navigate"
                                           Style="{StaticResource AboutActionLink}" FontSize="12">Issues</Hyperlink>
                                <Run Text=" — Report bugs or request features" FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </TextBlock>
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/jasperdevs/odd-snap/blob/main/LICENSE" RequestNavigate="Hyperlink_Navigate"
                                           Style="{StaticResource AboutActionLink}" FontSize="12">License</Hyperlink>
                                <Run Text=" — MIT" FontSize="11" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- History (merged: Screenshots + Text sub-tabs) -->
            <Grid x:Name="HistoryPanel" Visibility="Collapsed" Margin="32,52,32,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Category dropdown + actions -->
                <Border Grid.Row="0" Padding="0,0,0,8">
                    <StackPanel>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="SelectBtn" Content="Select" Style="{StaticResource HistoryActionButton}"
                                         Margin="0,0,6,0" Click="ToggleSelectMode"/>
                                <Button x:Name="DeleteAllBtn" Content="Clear all" Style="{StaticResource HistoryDangerButton}"
                                        Click="DeleteAllClick"/>
                                <Button x:Name="DeleteSelectedBtn" Content="Delete selected" Style="{StaticResource HistoryDangerButton}"
                                         Margin="6,0,0,0" Visibility="Collapsed" Click="DeleteSelectedClick"/>
                            </StackPanel>
                            <ComboBox x:Name="HistoryCategoryCombo" FontSize="12" Padding="8,5" MinWidth="130" Margin="0,0,8,0"
                                      VerticalAlignment="Center" SelectionChanged="HistoryCategoryCombo_Changed"
                                      PreviewMouseLeftButtonDown="HistoryCategoryCombo_PreviewMouseLeftButtonDown">
                                <ComboBoxItem Content="Images" IsSelected="True"/>
                                <ComboBoxItem Content="Text"/>
                                <ComboBoxItem Content="Videos/GIFs"/>
                                <ComboBoxItem Content="Colors"/>
                                <ComboBoxItem Content="Stickers"/>
                            </ComboBox>
                        </DockPanel>

                        <Grid x:Name="ImageSearchRow" Margin="0,8,0,0" Visibility="Visible">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                            <Border Background="{DynamicResource ThemeInputBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                    BorderThickness="1" CornerRadius="7" Padding="10,6">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="ImageSearchIcon" Width="14" Height="14" Stretch="Uniform"
                                               VerticalAlignment="Center" Opacity="0.35"/>
                                        <Grid Grid.Column="1" Margin="8,0,0,0">
                                            <TextBox x:Name="ImageSearchBox" BorderThickness="0" Background="Transparent"
                                                     FontSize="12" Padding="0" MinHeight="0" Height="20" VerticalContentAlignment="Center"
                                                     TextChanged="ImageSearchBox_TextChanged"
                                                     PreviewKeyDown="ImageSearchBox_PreviewKeyDown"
                                                     GotKeyboardFocus="ImageSearchBox_FocusChanged"
                                                     LostKeyboardFocus="ImageSearchBox_FocusChanged"/>
                                            <TextBlock x:Name="ImageSearchPlaceholder" Text="Search screenshots, OCR text, or filenames..."
                                                       FontSize="12" Opacity="0.28" VerticalAlignment="Center"
                                                       IsHitTestVisible="False" Margin="0,0,0,0"/>
                                        </Grid>
                                    </Grid>

                                    <TextBlock x:Name="ImageSearchFiltersSummaryText" Visibility="Collapsed"/>
                                    <StackPanel x:Name="ReindexAllProgressPanel" Orientation="Horizontal" Visibility="Collapsed">
                                        <ProgressBar x:Name="ReindexAllProgressBar" Width="60" Height="3" IsIndeterminate="True" Visibility="Collapsed"/>
                                        <Button x:Name="ReindexAllBtn" Content="Index" Style="{StaticResource HistoryActionButton}" MinWidth="64" Click="ReindexAllBtn_Click"/>
                                    </StackPanel>
                                    <ProgressBar x:Name="ImageSearchLoadingBar" Width="110" Height="3"
                                                 IsIndeterminate="True" Visibility="Collapsed"
                                                 Margin="22,6,0,0" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                            <Button x:Name="ImageSearchFiltersBtn" Grid.Column="1" Content="Filters" Style="{StaticResource HistoryActionButton}"
                                    Margin="8,0,0,0" VerticalAlignment="Stretch" Click="ImageSearchFiltersBtn_Click">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="ImageSearchFiltersMenu" Placement="Bottom">
                                        <MenuItem x:Name="ImageSearchFileNameCheck" Header="File name" IsCheckable="True"
                                                  Checked="ImageSearchSourcesCheck_Changed" Unchecked="ImageSearchSourcesCheck_Changed"/>
                                        <MenuItem x:Name="ImageSearchOcrCheck" Header="OCR text" IsCheckable="True"
                                                  Checked="ImageSearchSourcesCheck_Changed" Unchecked="ImageSearchSourcesCheck_Changed"/>
                                        <Separator/>
                                        <MenuItem x:Name="ImageSearchExactMatchCheck" Header="Exact match" IsCheckable="True"
                                                  ToolTip="Require exact phrase/token matches"
                                                  Checked="ImageSearchExactMatchCheck_Changed" Unchecked="ImageSearchExactMatchCheck_Changed"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- Images history -->
                <ScrollViewer x:Name="ImagesPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,2,10,4"
                              ScrollChanged="HistoryPanel_ScrollChanged">
