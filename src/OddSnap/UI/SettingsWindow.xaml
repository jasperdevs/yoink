                <StackPanel>
                    <TextBlock Text="Updates" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE895;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Automatically check for updates" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Notify when a newer OddSnap release is available." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="AutoUpdateCheck" Grid.Column="2" Content="" FontSize="13" VerticalAlignment="Center"
                                          Checked="AutoUpdateCheck_Changed" Unchecked="AutoUpdateCheck_Changed"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE9D5;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="UpdateStatusText" Text="Checking for updates..." Style="{StaticResource SettingTitle}"/>
                                    <TextBlock x:Name="UpdateDetailText" Text="" Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <Button x:Name="CheckUpdatesButton" Grid.Column="2" Content="Check now" FontSize="11" Padding="10,5" Margin="8,0,0,0" VerticalAlignment="Center" Click="CheckUpdatesButton_Click"/>
                                <Button x:Name="DownloadUpdateButton" Grid.Column="3" Content="Open release" FontSize="11" Padding="10,5" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="Collapsed" Click="DownloadUpdateButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Support" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Optional ways to support ongoing work."
                                       FontSize="11.5" Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,14"/>

                            <Border Style="{StaticResource AboutActionRow}" MouseLeftButtonUp="KoFiSupport_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource AboutIconFrame}">
                                        <Image Source="pack://application:,,,/Assets/kofi_logo.png"
                                               Width="20" Height="20" Stretch="Uniform"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Ko-fi" FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                        <TextBlock Text="Support development with Ko-fi" FontSize="11"
                                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,1,8,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="Open" FontSize="11" Opacity="0.45"
                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource AboutActionRow}" Margin="0" MouseLeftButtonUp="PayPalSupport_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource AboutIconFrame}">
                                        <Viewbox Width="20" Height="20" Stretch="Uniform">
                                            <Canvas Width="52" Height="52">
                                                <Path Fill="#002991" Data="M38.914 13.35c0 5.574-5.144 12.15-12.927 12.15H18.49l-.368 2.322L16.373 39H7.056l5.605-36h15.095c5.083 0 9.082 2.833 10.555 6.77a9.687 9.687 0 0 1 .603 3.58z"/>
                                                <Path Fill="#60CDFF" Data="M44.284 23.7A12.894 12.894 0 0 1 31.53 34.5h-5.206L24.157 48H14.89l1.483-9 1.75-11.178.367-2.322h7.497c7.773 0 12.927-6.576 12.927-12.15 3.825 1.974 6.055 5.963 5.37 10.35z"/>
                                                <Path Fill="#008CFF" Data="M38.914 13.35C37.31 12.511 35.365 12 33.248 12h-12.64L18.49 25.5h7.497c7.773 0 12.927-6.576 12.927-12.15z"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="PayPal" FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                        <TextBlock Text="Send a one-time donation" FontSize="11"
                                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,1,8,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="Open" FontSize="11" Opacity="0.45"
                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,8,0,14"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingIconFrame}">
                            <TextBlock Text="&#xE7E8;" Style="{StaticResource SettingIconGlyph}"/>
                        </Border>
                        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Launch on startup" Style="{StaticResource SettingTitle}"/>
                            <TextBlock Text="Start OddSnap automatically when Windows starts." Style="{StaticResource SettingDescription}"/>
                        </StackPanel>
                        <CheckBox x:Name="StartWithWindowsCheck" Grid.Row="0" Grid.Column="2" Content="" FontSize="13"
                                  VerticalAlignment="Center"
                                  Checked="StartWithWindowsCheck_Changed" Unchecked="StartWithWindowsCheck_Changed"/>

                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,14,0,0">
                            <WrapPanel Orientation="Horizontal">
                                <Button Content="Export settings" FontSize="12" Padding="10,6" MinWidth="108"
                                        Margin="0,0,10,8" Click="ExportSettingsButton_Click"/>
                                <Button Content="Import settings" FontSize="12" Padding="10,6" MinWidth="108"
