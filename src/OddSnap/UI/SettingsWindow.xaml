                                <TextBlock Text="Base URL" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBox x:Name="ImmichUrlBox" FontSize="11" Padding="7,4" TextChanged="ImmichUrlBox_Changed"
                                         Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="API key" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="ImmichApiKeyBox" FontSize="11" Padding="7,4" TextChanged="ImmichApiKeyBox_Changed"
                                         Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                        </StackPanel>
                    </controls:ProviderSection>

                    <controls:ProviderSection x:Name="FtpSettings" Header="FTP" Visibility="Collapsed">
                        <StackPanel>
                                <TextBlock Text="FTP URL" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBox x:Name="FtpUrlBox" FontSize="11" Padding="7,4" TextChanged="FtpUrlBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Username" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="FtpUsernameBox" FontSize="11" Padding="7,4" TextChanged="FtpUsernameBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Password" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="FtpPasswordBox" FontSize="11" Padding="7,4" TextChanged="FtpPasswordBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Public URL base (optional)" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="FtpPublicUrlBox" FontSize="11" Padding="7,4" TextChanged="FtpPublicUrlBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                        </StackPanel>
                    </controls:ProviderSection>

                    <controls:ProviderSection x:Name="SftpSettings" Header="SFTP" Visibility="Collapsed">
                        <StackPanel>
                                <TextBlock Text="Host" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBox x:Name="SftpHostBox" FontSize="11" Padding="7,4" TextChanged="SftpHostBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Port" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpPortBox" FontSize="11" Padding="7,4" TextChanged="SftpPortBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Username" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpUsernameBox" FontSize="11" Padding="7,4" TextChanged="SftpUsernameBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Password" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpPasswordBox" FontSize="11" Padding="7,4" TextChanged="SftpPasswordBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Remote path" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpRemotePathBox" FontSize="11" Padding="7,4" TextChanged="SftpRemotePathBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Public URL base (optional)" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpPublicUrlBox" FontSize="11" Padding="7,4" TextChanged="SftpPublicUrlBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Server fingerprint (SHA256 hex)" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="SftpHostKeyFingerprintBox" FontSize="11" Padding="7,4" TextChanged="SftpHostKeyFingerprintBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                        </StackPanel>
                    </controls:ProviderSection>

                    <controls:ProviderSection x:Name="WebDavSettings" Header="WEBDAV" Visibility="Collapsed">
                        <StackPanel>
                                <TextBlock Text="WebDAV URL" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                <TextBox x:Name="WebDavUrlBox" FontSize="11" Padding="7,4" TextChanged="WebDavUrlBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Username" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="WebDavUsernameBox" FontSize="11" Padding="7,4" TextChanged="WebDavUsernameBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Password" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="WebDavPasswordBox" FontSize="11" Padding="7,4" TextChanged="WebDavPasswordBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                                <TextBlock Text="Public URL base (optional)" FontSize="12" Opacity="0.6" Margin="0,8,0,4"/>
                                <TextBox x:Name="WebDavPublicUrlBox" FontSize="11" Padding="7,4" TextChanged="WebDavPublicUrlBox_Changed" Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"/>
                        </StackPanel>
                    </controls:ProviderSection>

                    <!-- Custom HTTP settings -->
                    <controls:ProviderSection x:Name="CustomUploadSettings" Header="CUSTOM HTTP" Visibility="Collapsed">
                        <controls:ProviderSection.HeaderExtras>
                            <Border Width="16" Height="16" CornerRadius="3" Background="#5865F2" Margin="0,0,6,0" VerticalAlignment="Center">
                                <TextBlock Text="&#x2B06;" FontSize="9" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                            </Border>
                        </controls:ProviderSection.HeaderExtras>
                        <StackPanel>
                            <TextBlock Text="Upload URL" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                            <TextBox x:Name="CustomUrlBox" FontSize="11" Padding="7,4"
                                     Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                     TextChanged="CustomUrlBox_Changed"/>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <TextBlock Text="File form field name" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                            <TextBox x:Name="CustomFieldBox" FontSize="11" Padding="7,4" Text="file"
                                     Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                     TextChanged="CustomFieldBox_Changed"/>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <TextBlock Text="Response JSON path to URL" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                            <TextBox x:Name="CustomJsonPathBox" FontSize="11" Padding="7,4" Text="url"
                                     ToolTip="Dot-separated path, e.g. data.url or just url"
                                     Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                     TextChanged="CustomJsonPathBox_Changed"/>

                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                            <TextBlock Text="Custom headers" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                            <TextBox x:Name="CustomHeadersBox" FontSize="11" Padding="7,4" AcceptsReturn="True"
                                     ToolTip="One per line, format: Name: Value"
                                     Height="70" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                     TextChanged="CustomHeadersBox_Changed"/>
                        </StackPanel>
                    </controls:ProviderSection>

                    <TextBlock x:Name="AutoUploadHeader" Text="Auto-upload" Style="{StaticResource SectionLabel}" Margin="4,18,0,9"/>

                    <Border x:Name="AutoUploadCard" Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE722;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Auto-upload screenshots" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Upload images immediately after capture." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="AutoUploadScreenshotsCheck" Grid.Column="2" Content="" FontSize="13"
                                          ToolTip="Uploads after every capture"
                                          Checked="AutoUploadScreenshotsCheck_Changed" Unchecked="AutoUploadScreenshotsCheck_Changed"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE714;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Auto-upload GIFs" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Upload animated GIF captures after recording." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="AutoUploadGifsCheck" Grid.Column="2" Content="" FontSize="13"
                                          Checked="AutoUploadGifsCheck_Changed" Unchecked="AutoUploadGifsCheck_Changed"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE714;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Auto-upload videos" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Upload video captures when recording completes." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="AutoUploadVideosCheck" Grid.Column="2" Content="" FontSize="13"
                                          Checked="AutoUploadVideosCheck_Changed" Unchecked="AutoUploadVideosCheck_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Test upload -->
                    <TextBlock Text="Test" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"
                               Visibility="{Binding Visibility, ElementName=TestUploadCard}"/>
                    <Border Style="{StaticResource Card}" x:Name="TestUploadCard" Visibility="Collapsed">
                        <Grid Style="{StaticResource SettingRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource SettingIconFrame}">
                                <TextBlock Text="&#xE9D5;" Style="{StaticResource SettingIconGlyph}"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Test upload" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="Send a tiny image to verify this upload setup." Style="{StaticResource SettingDescription}"/>
                            </StackPanel>
                            <Button x:Name="TestUploadBtn" Grid.Column="2" Content="Test Upload" FontSize="12" Padding="12,6"
                                    ToolTip="Sends a tiny 1x1 pixel image to test your configuration"
                                    Click="TestUpload_Click" Cursor="Hand"/>
                        </Grid>
                    </Border>
                    </StackPanel>

                    <StackPanel x:Name="AiRedirectUploadsPanel" Visibility="Collapsed">
                        <TextBlock Text="Destination" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource Card}">
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE950;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="AI tool" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Choose the app OddSnap opens after an AI redirect capture." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <ComboBox x:Name="AiRedirectProviderCombo" Grid.Column="2" FontSize="12" Padding="8,5" Width="300" MaxDropDownHeight="240"
                                          SelectionChanged="AiRedirectProviderCombo_Changed">
                                    <ComboBoxItem Content="None" Tag="-1"/>
                                    <ComboBoxItem Content="ChatGPT" Tag="0"/>
                                    <ComboBoxItem Content="Claude" Tag="1"/>
                                    <ComboBoxItem Content="Gemini" Tag="3"/>
                                    <ComboBoxItem Content="Google Lens" Tag="4"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <TextBlock Text="Hotkey" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"/>
                        <Border Style="{StaticResource Card}">
                            <Grid x:Name="AiRedirectHotkeyPanelRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE765;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="AI Redirect hotkey" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Capture and send a region to the selected AI tool." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBox x:Name="AiRedirectPanelHotkeyBox"
                                             Style="{StaticResource HotkeyBox}"
                                             GotFocus="AiRedirectPanelHotkeyBox_GotFocus"
                                             LostFocus="AiRedirectPanelHotkeyBox_LostFocus"
                                             PreviewKeyDown="AiRedirectPanelHotkeyBox_PreviewKeyDown"
                                             PreviewKeyUp="AiRedirectPanelHotkeyBox_PreviewKeyUp"/>
                                    <Button x:Name="AiRedirectPanelHotkeyClearBtn"
                                            Content="×"
                                            Style="{StaticResource ClearBtn}"
                                            Click="AiRedirectPanelHotkeyClearBtn_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel x:Name="AiRedirectLensUploadHostPanelRow" Visibility="Collapsed">
                            <TextBlock Text="Hosted Image" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"/>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE8AB;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Synced with Images uploads" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Use the same image host for Google Lens redirects." Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="AiRedirectLensUploadSyncCheck" Grid.Column="2"
                                                  Content=""
                                                  FontSize="13"
                                                  Checked="AiRedirectLensUploadSyncCheck_Changed"
                                                  Unchecked="AiRedirectLensUploadSyncCheck_Changed"/>
                                    </Grid>
                                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE898;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Lens upload service" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Pick the public host used before opening Google Lens." Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="AiRedirectLensUploadDestPanelCombo" Grid.Column="2" FontSize="12" Padding="8,5" Width="300" MaxDropDownHeight="280"
                                                  SelectionChanged="AiRedirectLensUploadDestPanelCombo_Changed"/>
                                    </Grid>
                                    <TextBlock x:Name="AiRedirectLensUploadPanelHint" Visibility="Collapsed"
                                               Text="Google Lens needs a public image URL, so OddSnap uploads first and then opens Lens."
                                               FontSize="11" Opacity="0.24" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="StickerUploadsPanel" Visibility="Collapsed">
                        <TextBlock Text="Provider" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource Card}">
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SettingIconFrame}">
                                        <TextBlock Text="&#xE91B;" Style="{StaticResource SettingIconGlyph}"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Sticker provider" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Text="Choose the background removal engine for sticker captures." Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <ComboBox x:Name="StickerProviderCombo" Grid.Column="2" FontSize="12" Padding="8,5" Width="300" MaxDropDownHeight="240"
                                              SelectionChanged="StickerProviderCombo_Changed">
                                        <ComboBoxItem Content="None"/>
                                        <ComboBoxItem Content="Remove.bg"/>
                                        <ComboBoxItem Content="Photoroom"/>
                                        <ComboBoxItem Content="Local (CPU/GPU)"/>
                                    </ComboBox>
                                </Grid>
                        </Border>

                                <StackPanel x:Name="StickerRemoveBgPanel" Visibility="Collapsed">
                                    <TextBlock Text="remove.bg API key" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                    <TextBox x:Name="StickerRemoveBgKeyBox" FontSize="11" Padding="7,4"
                                             Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                             TextChanged="StickerRemoveBgKeyBox_Changed"/>
                                </StackPanel>

                                <StackPanel x:Name="StickerPhotoroomPanel" Visibility="Collapsed">
                                    <TextBlock Text="Photoroom API key" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                    <TextBox x:Name="StickerPhotoroomKeyBox" FontSize="11" Padding="7,4"
                                             Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                             TextChanged="StickerPhotoroomKeyBox_Changed"/>
                                </StackPanel>

                                <StackPanel x:Name="StickerLocalCpuPanel" Visibility="Collapsed">
                                    <TextBlock Text="Local Models" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"/>

                                    <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE950;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Execution mode" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Choose CPU or CUDA acceleration for local stickers." Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="StickerLocalExecutionCombo" Grid.Column="2" FontSize="12" Padding="8,5" Width="300" MaxDropDownHeight="220"
                                                  SelectionChanged="StickerLocalExecutionCombo_Changed">
                                            <ComboBoxItem Content="CPU"/>
                                            <ComboBoxItem Content="GPU (CUDA)"/>
                                        </ComboBox>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>

                                    <Grid x:Name="StickerLocalCpuEnginePanel" Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE964;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="CPU model" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Pick the local model used without GPU acceleration." Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="StickerLocalCpuEngineCombo" Grid.Column="2" FontSize="12" Padding="8,5" Width="300" MaxDropDownHeight="240"
                                                      SelectionChanged="StickerLocalCpuEngineCombo_Changed">
                                            <ComboBoxItem Content="BRIA RMBG" Tag="BriaRmbg"/>
                                            <ComboBoxItem Content="BiRefNet Lite (High quality)" Tag="BiRefNetLite"/>
                                            <ComboBoxItem Content="ISNet General Use (Balanced)" Tag="IsNetGeneralUse"/>
                                            <ComboBoxItem Content="U2Netp (Fastest)" Tag="U2Netp"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid x:Name="StickerLocalGpuEnginePanel" Style="{StaticResource SettingRow}" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE950;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="GPU model" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Pick the CUDA model used for local stickers." Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="StickerLocalGpuEngineCombo" Grid.Column="2" FontSize="12" Padding="8,5" Width="300" MaxDropDownHeight="240"
                                                      SelectionChanged="StickerLocalGpuEngineCombo_Changed">
                                            <ComboBoxItem Content="BRIA RMBG" Tag="BriaRmbg"/>
                                            <ComboBoxItem Content="BiRefNet Lite (High quality)" Tag="BiRefNetLite"/>
                                            <ComboBoxItem Content="ISNet General Use (Balanced)" Tag="IsNetGeneralUse"/>
                                            <ComboBoxItem Content="U2Netp (Fastest)" Tag="U2Netp"/>
                                        </ComboBox>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>

                                    <TextBlock x:Name="StickerLocalEngineStatusText" Text="Pick a model. Models download automatically on first use." FontSize="11" Opacity="0.35" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="StickerLocalEngineProgress" Height="6" Margin="0,8,0,0" Minimum="0" Maximum="100" Visibility="Collapsed"/>
                                    <TextBlock x:Name="StickerLocalEngineProgressText" FontSize="10" Opacity="0.25" Margin="0,4,0,0" Visibility="Collapsed"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button x:Name="StickerInstallDriversBtn" Content="Install runtime" FontSize="12" Padding="12,6"
                                                Click="StickerInstallDriversBtn_Click" Cursor="Hand"/>
                                        <Button x:Name="StickerDownloadRembgBtn" Content="Download model" FontSize="12" Padding="12,6"
                                                Margin="8,0,0,0" Click="StickerDownloadRembgBtn_Click" Cursor="Hand"/>
                                        <Button x:Name="StickerOpenLocalEngineRepoBtn" Content="Open engine project" FontSize="12" Padding="12,6" Margin="8,0,0,0"
                                                Click="StickerOpenLocalEngineRepoBtn_Click" Cursor="Hand"/>
                                        <Button x:Name="StickerRemoveAllModelsBtn" Content="Remove all models" FontSize="12" Padding="12,6" Margin="8,0,0,0"
                                                Click="StickerRemoveAllModelsBtn_Click" Cursor="Hand" Visibility="Collapsed"/>
                                        <Button x:Name="StickerCopyErrorBtn" Content="Copy status" FontSize="12" Padding="12,6" Margin="8,0,0,0"
                                                Click="StickerCopyErrorBtn_Click" Cursor="Hand" Visibility="Collapsed"/>
                                    </StackPanel>
                                    </StackPanel>
                                    </Border>

                                    <TextBlock Text="Output" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"/>

                                    <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE790;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Add drop shadow" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Give generated stickers a subtle shadow." Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="StickerShadowCheck" Grid.Column="2" Content="" FontSize="13"
                                                  Checked="StickerShadowCheck_Changed" Unchecked="StickerShadowCheck_Changed"/>
                                    </Grid>
                                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE9A6;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Add white stroke" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Add a clean border around generated stickers." Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="StickerStrokeCheck" Grid.Column="2" Content="" FontSize="13"
                                                  Checked="StickerStrokeCheck_Changed" Unchecked="StickerStrokeCheck_Changed"/>
                                    </Grid>
                                    </StackPanel>
                                    </Border>
                                </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="UpscaleUploadsPanel" Visibility="Collapsed">
                        <TextBlock Text="Provider" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource Card}">
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SettingIconFrame}">
                                        <TextBlock Text="&#xE7B3;" Style="{StaticResource SettingIconGlyph}"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Upscale provider" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Text="Choose the engine used for upscale captures." Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <ComboBox x:Name="UpscaleProviderCombo" Grid.Column="2" FontSize="12" Padding="8,5" Width="300" MaxDropDownHeight="240"
                                              SelectionChanged="UpscaleProviderCombo_Changed">
                                        <ComboBoxItem Content="None"/>
                                        <ComboBoxItem Content="Local (CPU/GPU)"/>
                                        <ComboBoxItem Content="DeepAI Super Resolution"/>
                                        <ComboBoxItem Content="DeepAI Waifu2x"/>
                                    </ComboBox>
                                </Grid>
                        </Border>

                                <StackPanel x:Name="UpscaleDeepAiPanel" Visibility="Collapsed" Margin="0,0,0,10">
                                    <TextBlock Text="DeepAI API key" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UpscaleDeepAiApiKeyBox" FontSize="11" Padding="7,4"
                                             Background="{DynamicResource ThemeInputBackgroundBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                             TextChanged="UpscaleDeepAiApiKeyBox_Changed"/>
                                    <TextBlock Text="Optional cloud providers. Local remains the default." FontSize="11" Opacity="0.32" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel x:Name="UpscaleLocalPanel" Visibility="Collapsed">
                                    <TextBlock Text="Local Models" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"/>

                                    <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE950;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Execution mode" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Choose CPU or CUDA acceleration for local upscaling." Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="UpscaleLocalExecutionCombo" Grid.Column="2" FontSize="12" Padding="8,5" Width="300" MaxDropDownHeight="220"
                                                  SelectionChanged="UpscaleLocalExecutionCombo_Changed">
                                            <ComboBoxItem Content="CPU"/>
                                            <ComboBoxItem Content="GPU (CUDA)"/>
                                        </ComboBox>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>

                                    <Grid x:Name="UpscaleLocalCpuEnginePanel" Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE964;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="CPU model" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Pick the local model used without GPU acceleration." Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="UpscaleLocalCpuEngineCombo" Grid.Column="2" FontSize="12" Padding="8,5" Width="300" MaxDropDownHeight="220"
                                                      SelectionChanged="UpscaleLocalCpuEngineCombo_Changed">
                                            <ComboBoxItem Content="SwinIR x4 (Faithful / UI)" Tag="SwinIrRealWorld"/>
                                            <ComboBoxItem Content="Real-ESRGAN x4plus (Heavier)" Tag="RealEsrganX4Plus"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid x:Name="UpscaleLocalGpuEnginePanel" Style="{StaticResource SettingRow}" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE950;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="GPU model" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Pick the CUDA model used for local upscaling." Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="UpscaleLocalGpuEngineCombo" Grid.Column="2" FontSize="12" Padding="8,5" Width="300" MaxDropDownHeight="220"
                                                      SelectionChanged="UpscaleLocalGpuEngineCombo_Changed">
                                            <ComboBoxItem Content="Real-ESRGAN x4plus (Best quality)" Tag="RealEsrganX4Plus"/>
                                            <ComboBoxItem Content="SwinIR x4 (Faithful / UI)" Tag="SwinIrRealWorld"/>
                                        </ComboBox>
                                    </Grid>
                                    <TextBlock x:Name="UpscaleLocalEngineStatusText" Text="Pick a model. Models download automatically on first use." FontSize="11" Opacity="0.35" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="UpscaleLocalEngineProgress" Height="6" Margin="0,8,0,0" Minimum="0" Maximum="100" Visibility="Collapsed"/>
                                    <TextBlock x:Name="UpscaleLocalEngineProgressText" FontSize="10" Opacity="0.25" Margin="0,4,0,0" Visibility="Collapsed"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button x:Name="UpscaleInstallDriversBtn" Content="Install runtime" FontSize="12" Padding="12,6"
                                                Click="UpscaleInstallDriversBtn_Click" Cursor="Hand"/>
                                        <Button x:Name="UpscaleDownloadModelBtn" Content="Download model" FontSize="12" Padding="12,6"
                                                Margin="8,0,0,0" Click="UpscaleDownloadModelBtn_Click" Cursor="Hand"/>
                                        <Button x:Name="UpscaleOpenLocalEngineRepoBtn" Content="Open engine project" FontSize="12" Padding="12,6" Margin="8,0,0,0"
                                                Click="UpscaleOpenLocalEngineRepoBtn_Click" Cursor="Hand"/>
                                        <Button x:Name="UpscaleRemoveAllModelsBtn" Content="Remove all models" FontSize="12" Padding="12,6" Margin="8,0,0,0"
                                                Click="UpscaleRemoveAllModelsBtn_Click" Cursor="Hand" Visibility="Collapsed"/>
                                        <Button x:Name="UpscaleCopyErrorBtn" Content="Copy status" FontSize="12" Padding="12,6" Margin="8,0,0,0"
                                                Click="UpscaleCopyErrorBtn_Click" Cursor="Hand" Visibility="Collapsed"/>
                                    </StackPanel>
                                    </StackPanel>
                                    </Border>

                                    <TextBlock Text="Result Behavior" Style="{StaticResource SectionLabel}" Margin="4,8,0,9"/>

                                    <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE8A7;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Show preview window" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Open the upscale preview after selecting an image." Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <CheckBox x:Name="UpscaleShowPreviewWindowCheck"
                                                  Grid.Column="2"
                                                  Content=""
                                                  FontSize="13"
                                                  Checked="UpscaleShowPreviewWindowCheck_Changed"
                                                  Unchecked="UpscaleShowPreviewWindowCheck_Changed"/>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SettingIconFrame}">
                                            <TextBlock Text="&#xE8A7;" Style="{StaticResource SettingIconGlyph}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Default multiplier" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock x:Name="UpscaleDefaultScaleHelpText"
                                                       Text="Used when preview is off."
                                                       Style="{StaticResource SettingDescription}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ComboBox x:Name="UpscaleDefaultScaleCombo"
                                                  Grid.Column="2"
                                                  FontSize="12"
                                                  Padding="8,5"
                                                  MinWidth="120"
                                                  Margin="10,0,0,0"
                                                  SelectionChanged="UpscaleDefaultScaleCombo_Changed"/>
                                    </Grid>
                                    </StackPanel>
                                    </Border>

                                </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
    </Grid>
    </Border>
    </Border>
</Window>
