<Window x:Class="OddSnap.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:OddSnap.UI.Controls"
        Title="OddSnap"
        Height="660" Width="940"
        MinHeight="580" MinWidth="820"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Icon="pack://application:,,,/oddsnap.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#FFF0F0F0"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#FF9A9A9A"/>
        <SolidColorBrush x:Key="ThemeMutedBrush" Color="#FF686868"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="ThemeTabActiveBrush" Color="#18FFFFFF"/>
        <SolidColorBrush x:Key="ThemeTabHoverBrush" Color="#0EFFFFFF"/>
        <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ThemeWindowBorderBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ThemeSeparatorBrush" Color="#0CFFFFFF"/>

        <Style x:Key="TabPill" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="16,7" CornerRadius="7" Cursor="Hand" Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="12.5"
                                       FontFamily="Segoe UI Variable Text"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.55"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="1"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubTab" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="12,5" CornerRadius="6" Cursor="Hand" Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="11.5"
                                       FontFamily="Segoe UI Variable Text"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.92"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="Medium"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tb" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Opacity" Value="0.96"/>
            <Setter Property="Margin" Value="0,6,0,8"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Bd" Padding="12,0" Height="38" CornerRadius="4" Cursor="Hand" Background="Transparent"
                                    Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="Icon" Grid.Column="0" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="16" Text="&#xE713;" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                               Opacity="0.74" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Tb" Grid.Column="1" Text="{TemplateBinding Content}" FontSize="13"
                                               FontFamily="Segoe UI Variable Text"
                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.82"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="General">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE9E9;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Toast">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE7F4;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Tools">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE90F;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Capture">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE722;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Recording">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE714;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="OCR">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE8B7;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="History">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE81C;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Uploads">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE898;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="About">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE946;"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="1"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Icon" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.9"/>
                                <Setter TargetName="Icon" Property="Opacity" Value="0.84"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Opacity" Value="0.68"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource ChromeButtonBase}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track"
                                Width="40"
                                Height="20"
                                CornerRadius="10"
                                Background="#00000000"
                                BorderBrush="{DynamicResource ThemeTextSecondaryBrush}"
                                BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <Ellipse x:Name="Thumb"
                                     Width="12"
                                     Height="12"
                                     Margin="4,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource ThemeTextSecondaryBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SettingRow" TargetType="Grid">
            <Setter Property="MinHeight" Value="62"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="SettingTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SettingDescription" TargetType="TextBlock" BasedOn="{StaticResource InfoText}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>

        <Style x:Key="SettingIconFrame" TargetType="Border">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SettingIconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Opacity" Value="0.92"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="AboutActionLink" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="TextDecorations" Value="{x:Null}"/>
        </Style>

        <Style x:Key="AboutActionRow" TargetType="Border">
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="AboutIconFrame" TargetType="Border">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InlineTagChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style x:Key="InlineTagChipDanger" TargetType="Border" BasedOn="{StaticResource InlineTagChip}">
            <Setter Property="Background" Value="#30EF4444"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource OddSnapDangerButton}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="HistoryActionButton" TargetType="Button" BasedOn="{StaticResource ChromeButtonBase}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="HistoryDangerButton" TargetType="Button" BasedOn="{StaticResource DangerButton}">
            <Setter Property="MinWidth" Value="82"/>
        </Style>

        <Style x:Key="HistoryActionsMenuStyle" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="MinWidth" Value="156"/>
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryActionsMenuItem" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="148"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                MinHeight="{TemplateBinding MinHeight}"
                                CornerRadius="4"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProviderIconFrame" TargetType="Border">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ProviderIconImage" TargetType="Image">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style TargetType="{x:Type controls:ProviderSection}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:ProviderSection}">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel x:Name="ProviderHeaderRow" Margin="0,0,0,12" LastChildFill="True">
                                    <ContentControl x:Name="HeaderExtrasHost"
                                                    DockPanel.Dock="Right"
                                                    Content="{TemplateBinding HeaderExtras}"
                                                    VerticalAlignment="Center"/>
                                    <Border x:Name="ProviderHeaderIconFrame" Style="{StaticResource SettingIconFrame}">
                                        <Image x:Name="ProviderHeaderIcon"
                                               Source="{TemplateBinding IconSource}"
                                               Width="16"
                                               Height="16"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"
                                               FontFamily="Segoe UI Variable Text"
                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                               Opacity="0.82"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                                <ContentPresenter Content="{TemplateBinding Content}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Header" Value="{x:Null}">
                                <Setter TargetName="ProviderHeaderRow" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IconSource" Value="{x:Null}">
                                <Setter TargetName="ProviderHeaderIconFrame" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HeaderExtras" Value="{x:Null}">
                                <Setter TargetName="HeaderExtrasHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

        <Border Margin="1" CornerRadius="12">
    <Border x:Name="OuterBorder" CornerRadius="12" ClipToBounds="True"
            BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:OddSnapTitleBar Grid.Row="0"
                                  Title="Settings"
                                  CloseRequested="TitleBar_CloseRequested"/>

        <!-- Sidebar + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar navigation -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource ThemeSeparatorBrush}" BorderThickness="0,0,1,0"
                    Padding="16,14,12,18">
                <StackPanel>
                    <RadioButton x:Name="SettingsTab" Content="General" GroupName="Main"
                                 IsChecked="True" Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <RadioButton x:Name="ToastTab" Content="Toast" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <RadioButton x:Name="HotkeysTab" Content="Tools" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <RadioButton x:Name="CaptureTab" Content="Capture" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <RadioButton x:Name="RecordingTab" Content="Recording" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <RadioButton x:Name="OcrTab" Content="OCR" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>
                    <RadioButton x:Name="HistoryTab" Content="History" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <RadioButton x:Name="UploadsTab" Content="Uploads" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,10,0,10"/>
                    <RadioButton x:Name="AboutTab" Content="About" GroupName="Main"
                                 Click="TabChanged" Style="{StaticResource NavItem}"/>
                </StackPanel>
            </Border>

            <!-- Content area -->
            <Grid Grid.Column="1">
                <TextBlock x:Name="PageTitleText"
                           Text="General"
                           Margin="32,12,32,0"
                           FontSize="24"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display"
                           Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                           Panel.ZIndex="10"
                           IsHitTestVisible="False"/>


            <!-- Tools (unified hotkeys + toolbar) -->
            <ScrollViewer x:Name="HotkeysPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="32,52,32,24">
                <StackPanel>
                    <CheckBox x:Name="ShowToolNumberBadgesCheck" Visibility="Collapsed"
                              Checked="ShowToolNumberBadgesCheck_Changed" Unchecked="ShowToolNumberBadgesCheck_Changed"/>
                    <StackPanel x:Name="ToolTogglePanel"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Capture + Saving -->
            <ScrollViewer x:Name="CapturePanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="32,52,32,24">
                <StackPanel>
                    <TextBlock Text="Capture Tool" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE722;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Default capture tool" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Choose which selection mode opens first." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <ComboBox x:Name="DefaultCaptureModeCombo" Grid.Column="2" FontSize="12.5" Padding="10,5" MinWidth="170"
                                          VerticalAlignment="Center"
                                          SelectionChanged="DefaultCaptureModeCombo_SelectionChanged">
                                    <ComboBoxItem Content="Rectangle"/>
                                    <ComboBoxItem Content="Center"/>
                                    <ComboBoxItem Content="Freeform"/>
                                </ComboBox>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE1D9;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Center aspect ratio" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Optional ratio lock for center selection." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <ComboBox x:Name="CenterAspectRatioCombo" Grid.Column="2" FontSize="12.5" Padding="10,5" MinWidth="170"
                                          VerticalAlignment="Center"
                                          SelectionChanged="CenterAspectRatioCombo_SelectionChanged">
                                    <ComboBoxItem Content="Free"/>
                                    <ComboBoxItem Content="Square"/>
                                    <ComboBoxItem Content="16:9"/>
                                    <ComboBoxItem Content="4:3"/>
                                    <ComboBoxItem Content="3:2"/>
                                    <ComboBoxItem Content="9:16"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Selection overlay" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"/>
                    <Border Style="{StaticResource Card}">
