<UserControl x:Class="OddSnap.UI.Controls.OddSnapTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="40">
    <Border x:Name="TitleBarBorder"
            MinHeight="40"
            Padding="14,0,0,0"
            CornerRadius="11,11,0,0"
            Background="Transparent"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image x:Name="TitleLogo"
                       Height="17"
                       Width="0"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center"
                       Opacity="0"
                       Visibility="Collapsed"/>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Text"
                           Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                <Border x:Name="MinimizeBtn"
                        Style="{StaticResource OddSnapTitleButton}"
                        MouseLeftButtonDown="MinimizeBtn_MouseLeftButtonDown"
                        MouseEnter="TitleBtn_MouseEnter"
                        MouseLeave="TitleBtn_MouseLeave">
                    <Image x:Name="MinimizeIcon" Style="{StaticResource OddSnapTitleButtonIcon}"/>
                </Border>
                <Border x:Name="CloseBtn"
                        Style="{StaticResource OddSnapTitleCloseButton}"
                        MouseLeftButtonDown="CloseBtn_MouseLeftButtonDown"
                        MouseEnter="TitleBtn_MouseEnter"
                        MouseLeave="TitleBtn_MouseLeave">
                    <Image x:Name="CloseIcon" Style="{StaticResource OddSnapTitleButtonIcon}"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
